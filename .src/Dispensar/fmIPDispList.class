' Gambas class file

Private $FieldList As String[]
Private $rData1 As Result
Private $aMyFields1 As String[]

Private $rData2 As Result
Private $aMyFields2 As String[]
Private $encid As String

Private $RestrictType As String
Private $RestrictList As String[]

Private $HiCappingVar As Collection
Private $HiCapAPIView As Variant[]

Public Sub Form_Open()

  Dim xregimen As String
  Dim xpackLst As String[]

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Column")
  Panel4.Width = Panel1.Width - (Panel3.Width + Panel9.Width)
  Me.Icon = Picture[modGeneralMain.$strLogo]

  $RestrictType = modGlobalSetting.ShowSettingFromDB("IPClinic/MedOrderVisibility")
  $RestrictList = modGlobalSetting.GetDBTableList("IPClinic/MedOrderVisibility")

  modSettings.ShowCheckBox(chkprintlabel, "DispensingList/PrintLabel")

  ShowDepartList()
  cmbdepart.Text = "%"
  xpackLst = modNonMedical.FillDiscountCombo()
  cmbpackage.List = xpackLst
  cmbpackage.Text = "%"

  xregimen = modSettings.ShowSettingFromFIle("ShowRegimen/DispensingList")
  If xregimen = "Yes" Then
    chkregimen.Value = True
  Else If xregimen = "No" Then
    chkregimen.Value = False
  Endif

  chkselall.Value = True
  txtsearch.SetFocus

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub cmbdepart_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbdepart)
  modFillContainer.RestrictComboToContent(cmbdepart)

End

Public Sub cmbpackage_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbpackage)
  modFillContainer.RestrictComboToContent(cmbpackage)

End

Public Sub cmbnewscheme_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbnewscheme)
  modFillContainer.RestrictComboToContent(cmbnewscheme)

End

Private Sub ShowDepartList()

  If modBasic.$FixedDepartment Then
    cmbdepart.Text = modBasic.$FixedDepartment
    If modBasic.$LockToOwnDepart = "Yes" Then
      cmbdepart.Enabled = False
    Endif
  Else
    cmbdepart.List = modGeneral.GetDepartmentAllList("Patient Ward")
  Endif

End

Public Sub form_KeyRelease()

  If Key.Code = Key["R"] And If Key.Control Then
    btnrefresh_Click()
  Else If Key.Code = Key.F1 Then
    txtsearch.SetFocus
  Else If Key.Code = Key.F12 Then
    btnclaerall_Click()
  Endif

End

Public Sub btnrefresh_Click()

  GridView2.Clear()
  GridView1.Clear()
  FillEncList("")

End

Private Sub FillEncList(xencid As String)

  Dim xsql As String

  If cmbdepart.Text = "%" And If cmbpackage.Text = "%" Then
    xsql = ""
  Else
    If cmbdepart.Text = "%" Then
      xsql = db.Subst(" and fldencounterval in(select fldencounterval from tblencounter where flddod IS NULL and flddisctype=&1)", cmbpackage.Text)
    Else If cmbpackage.Text = "%" Then
      xsql = db.Subst(" and fldencounterval in(select fldencounterval from tblencounter where flddod IS NULL and fldcurrlocat in(select fldbed from tbldepartmentbed where flddept like &1))", cmbdepart.Text)
    Else
      xsql = db.Subst(" and fldencounterval in(select fldencounterval from tblencounter where flddod IS NULL and flddisctype=&1 and fldcurrlocat in(select fldbed from tbldepartmentbed where flddept like &2))", cmbpackage.Text, cmbdepart.Text)
    Endif
  Endif

  $FieldList = ["fldencounterval", "fldencounterval", "fldencounterval", "fldencounterval"]
  If xencid Then
    $rData1 = modDatabase.$myConn.Exec("select " & $FieldList.Join(",") & " from tblinpatdosing where fldcurval=&1 and fldsave=&2 and fldendtime>=&3 and fldencounterval like &4 GROUP BY fldencounterval", "Continue", False, modDate.StartSqlDate(Now()), xencid)                                          ''
  Else
    $rData1 = modDatabase.$myConn.Exec("select " & $FieldList.Join(",") & " from tblinpatdosing where fldcurval=&1 and fldsave=&2 and fldendtime>=&3 GROUP BY fldencounterval", "Continue", False, modDate.StartSqlDate(Now()))                                          ''
  Endif
  $aMyFields1 = New String[]
  modGridView.ReadSmallData(GridView1, $rData1, $aMyFields1)

  With GridView1
    .Columns[0].Width = 100 * modBasic.$AppWidthRatio
    .Columns[1].Width = 125 * modBasic.$AppWidthRatio
    .Columns[2].Width = 175 * modBasic.$AppWidthRatio
    .Columns[3].Width = 125 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Location"
    .Columns[1].Text = "Encounter"
    .Columns[2].Text = "Name"
    .Columns[3].Text = "Scheme"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData1.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 0 Then
    GridView1.Data.Text = modPatient.GetPatientLocation($rData1[$aMyFields1[Column]])
  Else If Column = 2 Then
    GridView1.Data.Text = modPatient.GetPatientNameByEnc($rData1[$aMyFields1[Column]])
  Else If Column = 3 Then
    GridView1.Data.Text = modPatient.ShowDiscountCategEnc($rData1[$aMyFields1[Column]])
  Else
    GridView1.Data.Text = $rData1[$aMyFields1[Column]]
  Endif
  GridView1.Rows[Row].Height = Max(GridView1.Rows[Row].Height, GridView1.Data.Font.RichTextHeight(GridView1.Data.Text, GridView1.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (GridView1.Rows.Height - GridView1.Font.Height))
  GridView1.Data.WordWrap = True

End

Public Sub GridView1_Select()

  GridView1_Click()

End

Public Sub GridView1_Click()

  cmbnewscheme.Clear()
  If GridView1.Rows.Selection.Count Then
    GridView2.Clear()
    $encid = GridView1[GridView1.Row, 1].Text
    GetPatientProfile($encid)

    cmbnewscheme.List = modBasic.$BillDiscountCash
    If cmbnewscheme.List.Count = 0 Then
      cmbnewscheme.Add(GridView1[GridView1.Row, 3].Text)
    Endif
    cmbnewscheme.Text = GridView1[GridView1.Row, 3].Text

    FillDispenstable($encid)
    ShowMedicineOrderList($encid)
    $HiCappingVar = New Collection
    GridView2.SetFocus
  Endif

End

Private Sub GetPatientProfile(encid As String)

  txtpatientname.Text = modPatient.GetPatientNameByEnc(encid)
  txtstatus.Text = modPatient.CurrentAdmissionStatus(encid)
  txtagesex.Text = modPatient.GetPatientAgeString(encid, Now()) & "/" & modPatient.GetPatientAddressByEnc(encid)
  txtpatientcontact.Text = modPatient.GetPatientLocation(encid)
  txtnhsi.Text = modPatient.GetPatientExtCOdebyEnc(encid)

End

Private Sub ShowMedicineOrderList(encid As String)

  Dim xrestr As String
  Dim i As Integer
  Dim xList As String[]
  Dim Row As Integer
  Dim res As Result
  Dim pic2 As Picture

  If $RestrictType And If $RestrictList.Count Then
    xList = $RestrictList.Copy()
    For i = 0 To xList.Count - 1
      xList[i] = "'" & xList[i] & "'"
    Next
    If $RestrictType = "Allow" Then
      xrestr = " and flditem IN(" & xList.Join(",") & ")"
    Else If $RestrictType = "Prevent" Then
      xrestr = " and flditem NOT IN(" & xList.Join(",") & ")"
    Endif
  Else
    xrestr = ""
  Endif

  ListView1.Clear
  pic2 = Picture["icons/checked.png"]
  res = modDatabase.$myConn.Exec("select distinct(flditem) as flditem from tblinpatdosing where fldencounterval=&1 and fldcurval=&2 and fldsave=&3 and fldendtime>=&4" & xrestr, encid, "Continue", False, modDate.StartSqlDate(Now()))                 ''
  If res.Available Then
    Row = 1
    For Each res
      ListView1.Add(CStr(Row), res["flditem"], pic2)
      Row = Row + 1
    Next
  Endif

End

Public Sub ListView1_Click()

  ShowCheckedView()

End

Private Sub ShowCheckedView()

  Dim pic1 As Picture
  Dim pic2 As Picture

  pic1 = Picture["icons/unchecked.png"]
  pic2 = Picture["icons/checked.png"]

  If ListView1.Current.Picture = pic1 Then
    ListView1.Current.Picture = pic2
  Else If ListView1.Current.Picture = pic2 Then
    ListView1.Current.Picture = pic1
  Endif

End

Public Sub btnaddorder_Click()

  Dim Row As Integer
  Dim res As Result

  Dim xtax As Float
  Dim xdisc As Float
  Dim itemtype As String
  Dim xfixrate As Float
  Dim xfixname As String
  Dim itemmode As String
  Dim CPharmFix As CFixRatePharmacy
  Dim xgo As Boolean
  Dim xrestr As String

  Dim hForm As CPackageParams
  Dim xBillMode As String
  Dim xLedgerAC As String
  Dim xBillType As String
  Dim xsClaimState As String

  $HiCappingVar = New Collection
  hForm = New CPackageParams($encid, cmbnewscheme.Text)
  xBillMode = hForm.GetBillingMode()
  xLedgerAC = hForm.GetLedgerAC()
  xBillType = hForm.GetBillType()
  xsClaimState = hForm.GetClaimState()

  For Row = 1 To ListView1.Count
    If ListView1[Row].Picture = Picture["icons/checked.png"] Then
      res = modDatabase.$myConn.Exec("select fldid,fldroute,flditem,flddose,fldfreq,flddays,fldqtyorder,fldprescriber,fldregno,flddirection,fldadminsite,fldmixing,fldstarttime,fldendtime from tblinpatdosing where fldencounterval=&1 and flditem=&2 and fldcurval=&3 and fldsave=&4 and fldendtime>=&5" & xrestr, $encid, ListView1[Row].Text, "Continue", False, modDate.StartSqlDate(Now()))                 ''
      If res.Available Then
        For Each res

          itemtype = modNonMedical.GetBillItemCategoryFromCombo(res["fldroute"])
          xgo = False
          If modBasic.$BillPharmFixedModes.Exist(xBillMode) = True Then
            CPharmFix = New CFixRatePharmacy(itemtype, res["flditem"], xBillMode)
            xfixrate = CPharmFix.GetFixRate()
            xfixname = CPharmFix.GetFixItem()
            If xfixname Then
              xgo = True
            Else
              xgo = False
            Endif
          Else
            xgo = True
          Endif

          If xgo = True Then
            itemmode = xBillMode
            xtax = modNonMedical.ShowTaxValues(itemtype, res["flditem"])
            xdisc = modNonMedical.DiscPercentForCategoryValue($encid, cmbnewscheme.Text, itemtype, res["flditem"], itemmode)
            modPharmSub.InsertDosingMedicine($encid, xBillType, xBillMode, cmbnewscheme.Text, xLedgerAC, res["fldroute"], res["flditem"], res["flddose"], res["fldfreq"], res["flddays"], res["fldqtyorder"], txtstatus.Text, res["fldprescriber"], res["fldregno"], Now(), xtax, xdisc, xfixname, xfixrate, "Request", "IPD", res["flddirection"], res["fldadminsite"], 0, res["fldmixing"], res["fldid"], "Continue")
          Endif

        Next
      Endif
    Endif
  Next
  FillDispenstable($encid)

End

Private Function ExecuteQuery(encid As String) As Result

  Dim res As Result
  Dim xrestr As String
  Dim xList As String[]
  Dim i As Integer
  Dim xsql As String

  If $RestrictType And If $RestrictList.Count Then
    xList = $RestrictList.Copy()
    For i = 0 To xList.Count - 1
      xList[i] = "'" & xList[i] & "'"
    Next
    If $RestrictType = "Allow" Then
      xrestr = " and flditem IN(" & xList.Join(",") & ")"
    Else If $RestrictType = "Prevent" Then
      xrestr = " and flditem NOT IN(" & xList.Join(",") & ")"
    Endif
  Else
    xrestr = ""
  Endif

  If cmbdepart.Text Then
    xsql = db.Subst(" and fldencounterval in(select fldencounterval from tblencounter where fldcurrlocat in(select fldbed from tbldepartmentbed where flddept like &1))", cmbdepart.Text)
  Else
    xsql = ""
  Endif
  res = modDatabase.$myConn.Exec("select fldid,fldtime_order,fldroute,flditem,fldqtydisp,flddose,fldfreq,flddays,fldlabel,flddirection,fldcomp_order,fldencounterval,flditemtype,fldfixname,fldfixrate,fldtaxper,flddiscper,fldbillingmode,flddisctype,fldacledger,fldbilltype,fldcashincredit from tblpatdosing where fldencounterval=&1 and fldlevel=&2 and flditemtype like &3 and fldcurval=&4 and fldqtydisp>&5 and fldstatus=&6 and fldsave_order=&7" & xrestr & xsql, encid, "Requested", "%", "Continue", 0, "Admitted", False)

  Return res

End

Private Sub FillDispenstable(encid As String)

  $rData2 = ExecuteQuery(encid)
  $aMyFields2 = New String[]
  modGridView.ReadSmallData(GridView2, $rData2, $aMyFields2)

  With GridView2
    .Columns[0].Width = 1
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 250 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    If chkregimen.Value = True Then
      .Columns[5].Width = 75 * modBasic.$AppWidthRatio
      .Columns[6].Width = 50 * modBasic.$AppWidthRatio
      .Columns[7].Width = 50 * modBasic.$AppWidthRatio
      .Columns[8].Width = 25 * modBasic.$AppWidthRatio
    Else
      .Columns[5].Width = 1
      .Columns[6].Width = 1
      .Columns[7].Width = 1
      .Columns[8].Width = 1
    Endif

    .Columns[9].Width = 200 * modBasic.$AppWidthRatio
    .Columns[10].Width = 1
    .Columns[11].Width = 1
    .Columns[12].Width = 1

    .Columns[13].Width = 1
    .Columns[14].Width = 75 * modBasic.$AppWidthRatio
    .Columns[15].Width = 1
    .Columns[16].Width = 1
    .Columns[17].Width = 1
    .Columns[18].Width = 125 * modBasic.$AppWidthRatio
    .Columns[19].Width = 1
    .Columns[20].Width = 1
    .Columns[21].Width = 1

    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Route"
    .Columns[3].Text = "Particulars"
    .Columns[4].Text = "QTY"
    If chkregimen.Value = True Then
      .Columns[5].Text = "Dose"
      .Columns[6].Text = "Freq"
      .Columns[7].Text = "Day"
    Endif
    .Columns[9].Text = "Direction"
    .Columns[14].Text = "Rate"
    .Columns[18].Text = "Scheme"
  End With

End

Public Sub GridView2_Data(Row As Integer, Column As Integer)

  $rData2.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView2, Row)
  If Column = 1 Then
    GridView2.Data.Text = modReportVar.GetDateTimeReport($rData2[$aMyFields2[Column]], gb.GeneralDate)
  Else If Column = 8 Then
    GridView2.Data.Picture = Picture[modMisc.SetGridCheckIcon($rData2["fldlabel"])]
    GridView2.Data.Text = ""
  Else
    GridView2.Data.Text = $rData2[$aMyFields2[Column]]
  Endif
  GridView2.Rows[Row].Height = Max(GridView2.Rows[Row].Height, GridView2.Data.Font.RichTextHeight(GridView2.Data.Text, GridView2.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (GridView2.Rows.Height - GridView2.Font.Height))
  GridView2.Data.WordWrap = True

End

Public Sub GridView2_Click()

  Dim xval As Float
  Dim yval As String
  Dim col As Integer
  Dim row As Integer

  col = GridView2.Column
  row = GridView2.Row
  If GridView2.Column = 8 Then
    If GridView2[GridView2.Row, 12].Text = "Medicines" Then
      If GridView2[GridView2.Row, 4].Text And If GridView2[GridView2.Row, 5].Text And If GridView2[GridView2.Row, 6].Text Then
        modGridView.CheckUncheckGridWithDB(modDatabase.$myConn, GridView2, 8, "fldlabel", "fldid", "tblpatdosing", GridView2[GridView2.Row, 0].Text)
      Endif
    Endif

  Else If GridView2.Column = 4 Then
    xval = InputValue(GridView2[GridView2.Row, 3].Text, ("Alter Quantity"), GridView2[GridView2.Row, 4].Text)
    If xval > 0 Then
      modPharmSub.UpdateQTYBefDispensing(GridView2[GridView2.Row, 0].Text, xval)
      FillDispenstable($encid)
    Endif

  Else If GridView2.Column = 9 Then
    yval = InputBox(GridView2[GridView2.Row, 3].Text, ("Alter Direction"), GridView2[GridView2.Row, 9].Text)
    If yval Then
      modPharmSub.UpdateAdviceBefDispensing(GridView2[GridView2.Row, 0].Text, yval)
      FillDispenstable($encid)
    Endif

  Endif
  GridView2.Column = col
  GridView2.Row = row

End

