End

Public Sub btncounsel_Click()

  Dim Row As Integer
  Dim doslst As Long[]
  Dim xPath As String

  If GridView2.Rows.Count Then
    doslst = New Long[]
    For Row = 0 To GridView2.Rows.Count - 1
      If GridView2[Row, 12].Text = "Medicines" Then
        doslst.Add(GridView2[Row, 0].Text)
      Endif
    Next
    Inc Application.Busy
    xPath = modCHTMLPatient.ShowCounselingReport($encid, doslst)
    Dec Application.Busy
    modControlSub.OpenHTMLPreview($encid, xPath, "ReportSize")
  Endif

End

Public Sub btnreview_Click()

  Dim Row As Integer
  Dim xVar As Variant[]
  Dim xColl As Collection
  Dim cForm As CMedError
  Dim xPath As String

  If GridView2.Rows.Count Then
    xVar = New Variant[]
    For Row = 0 To GridView2.Rows.Count - 1
      If GridView2[Row, 12].Text = "Medicines" Then
        xColl = New Collection
        xColl.Add(GridView2[Row, 2].Text, "Route")
        xColl.Add(GridView2[Row, 3].Text, "Medicine")
        xColl.Add(GridView2[Row, 5].Text, "Dose")
        xColl.Add(GridView2[Row, 6].Text, "Frequency")
        xVar.Add(xColl)
      Endif
    Next

    cForm = New CMedError
    Inc Application.Busy
    xPath = cForm.ShowMedicationReviewMultipleDosIDReport($encid, xVar)
    Dec Application.Busy
    modControlSub.OpenHTMLPreview($encid, xPath, "ReportSize")
  Endif

End

