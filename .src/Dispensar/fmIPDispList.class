Private Sub ShowDispensedToday(encid As String)

  If chkalldate.Value = True Then
    $rData3 = modDatabase.$myConn.Exec("select fldid,fldtime,fldroute,flditem,fldqtydisp,flddose,fldfreq,flddays,fldlabel,flddirection,fldcomp,fldencounterval,flditemtype,fldfixname,fldfixrate,fldtaxper,flddiscper,fldbillingmode,flddisctype,fldacledger,fldbilltype,fldcashincredit from tblpatdosing where fldencounterval=&1 and fldlevel=&2 and flditemtype like &3 and fldcurval=&4 and fldqtydisp>&5 and fldstatus=&6 and fldsave_order=&7", encid, "Dispensed", "%", "Continue", 0, "Admitted", True)                     ''
  Else
    $rData3 = modDatabase.$myConn.Exec("select fldid,fldtime,fldroute,flditem,fldqtydisp,flddose,fldfreq,flddays,fldlabel,flddirection,fldcomp,fldencounterval,flditemtype,fldfixname,fldfixrate,fldtaxper,flddiscper,fldbillingmode,flddisctype,fldacledger,fldbilltype,fldcashincredit from tblpatdosing where fldencounterval=&1 and fldlevel=&2 and flditemtype like &3 and fldcurval=&4 and fldqtydisp>&5 and fldstatus=&6 and fldsave_order=&7 and fldtime>=&8 and fldtime<=&9", encid, "Dispensed", "%", "Continue", 0, "Admitted", True, modDate.StartSqlDate(dtdisp.Value), modDate.EndSqlDate(dtdisp.Value))                     ''
  Endif
  $aMyFields3 = New String[]
  modGridView.ReadSmallData(GridView3, $rData3, $aMyFields3)

  With GridView3
    .Columns[0].Width = 1
    .Columns[1].Width = 135 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 350 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    If chkregimen.Value = True Then
      .Columns[5].Width = 75 * modBasic.$AppWidthRatio
      .Columns[6].Width = 50 * modBasic.$AppWidthRatio
      .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    Else
      .Columns[5].Width = 1
      .Columns[6].Width = 1
      .Columns[7].Width = 1
    Endif

    .Columns[8].Width = 1
    .Columns[9].Width = 200 * modBasic.$AppWidthRatio
    .Columns[10].Width = 100 * modBasic.$AppWidthRatio
    .Columns[11].Width = 1
    .Columns[12].Width = 1

    .Columns[13].Width = 1
    .Columns[14].Width = 1 ''Fixed Rate
    .Columns[15].Width = 1
    .Columns[16].Width = 1
    .Columns[17].Width = 1
    .Columns[18].Width = 125 * modBasic.$AppWidthRatio
    .Columns[19].Width = 1
    .Columns[20].Width = 1
    .Columns[21].Width = 1

    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Route"
    .Columns[3].Text = "Particulars"
    .Columns[4].Text = "QTY"
    If chkregimen.Value = True Then
      .Columns[5].Text = "Dose"
      .Columns[6].Text = "Freq"
      .Columns[7].Text = "Day"
    Endif
    .Columns[9].Text = "Direction"
    .Columns[10].Text = "Location"
    .Columns[18].Text = "Scheme"
  End With

End

Public Sub GridView3_Data(Row As Integer, Column As Integer)

  $rData3.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView3, Row)
  If Column = 1 Then
    GridView3.Data.Text = modReportVar.GetDateTimeReport($rData3[$aMyFields3[Column]], gb.GeneralDate)
  Else If Column = 8 Then
    GridView3.Data.Text = ""
  Else
    GridView3.Data.Text = $rData3[$aMyFields3[Column]]
  Endif
  GridView3.Rows[Row].Height = Max(GridView3.Rows[Row].Height, GridView3.Data.Font.RichTextHeight(GridView3.Data.Text, GridView3.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (GridView3.Rows.Height - GridView3.Font.Height))
  GridView3.Data.WordWrap = True

End
