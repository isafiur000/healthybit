Public Sub GridView1_Click()

  cmbnewscheme.Clear()
  If GridView1.Rows.Selection.Count Then
    GridView2.Clear()
    $encid = GridView1[GridView1.Row, 1].Text
    GetPatientProfile($encid)

    cmbnewscheme.List = modNonMedical.GetHigherCostSchemes(modBasic.$BillDiscountCash, GridView1[GridView1.Row, 3].Text)
    If cmbnewscheme.List.Count = 0 Then
      cmbnewscheme.Add(GridView1[GridView1.Row, 3].Text)
    Endif
    cmbnewscheme.Text = GridView1[GridView1.Row, 3].Text
    If modNonMedical.GetAutoBillingLock($encid, GridView1[GridView1.Row, 3].Text) = True Then
      cmbnewscheme.Enabled = False
    Else
      cmbnewscheme.Enabled = True
    Endif

    FillDispenstable($encid)
    ShowDispensedToday($encid)
    ShowMedicineOrderList($encid)
    $HiCappingVar = New Collection
    GridView2.SetFocus
  Endif

End

Private Sub GetPatientProfile(encid As String)

  txtpatientname.Text = modPatient.GetPatientNameByEnc(encid)
  txtstatus.Text = modPatient.CurrentAdmissionStatus(encid)
  txtagesex.Text = modPatient.GetPatientAgeString(encid, Now()) & "/" & modPatient.GetPatientAddressByEnc(encid)
  txtpatientcontact.Text = modPatient.GetPatientLocation(encid)
  txtnhsi.Text = modPatient.GetPatientExtCOdebyEnc(encid)

End

Private Sub ShowMedicineOrderList(encid As String)

  Dim sql1 As String
  Dim sql2 As String
  Dim xrestr As String
  Dim i As Integer
  Dim xList As String[]
  Dim xroute As String

  If $RestrictType And If $RestrictList.Count Then
    xList = $RestrictList.Copy()
    For i = 0 To xList.Count - 1
      xList[i] = "'" & xList[i] & "'"
    Next
    If $RestrictType = "Allow" Then
      xrestr = " and flditem IN(" & xList.Join(",") & ")"
    Else If $RestrictType = "Prevent" Then
      xrestr = " and flditem NOT IN(" & xList.Join(",") & ")"
    Endif
  Else
    xrestr = ""
  Endif

  If cmbroute.Text Then
    Select cmbroute.Text
      Case "oral", "liquid", "fluid", "injection", "resp", "topical", "eye/ear", "anal/vaginal"
        xroute = db.Subst(" and flditem in(select fldbrandid from tblmedbrand where flddrug in(select flddrug from tbldrug where fldroute=&1))", cmbroute.Text)
      Case "suture", "msurg", "ortho"
        xroute = db.Subst(" and flditem in(select fldbrandid from tblsurgbrand where fldsurgid in(select fldsurgid from tblsurgicals where fldsurgcateg=&1))", cmbroute.Text)
      Case "extra"
        xroute = " and flditem in(select fldbrandid from tblextrabrand)"
    End Select
  Else
    xroute = " and "
  Endif

  sql1 = "select fldid,fldid,flditem,CONCAT(flddose, '|', fldfreq, '|', flddays),flduserid,fldcomp,fldencounterval from tblinpatdosing where fldencounterval=&1 and fldcurval=&2 and fldsave=&3 and flddays>&4 and fldendtime>=&5" & xrestr & xroute
  sql2 = "select fldid,fldid,flditem,CONCAT(flddose, '|', fldfreq, '|', flddays),flduserid,fldcomp,fldencounterval from tblinpatdosing where fldencounterval=&1 and fldcurval=&2 and fldsave=&3 and flddays=&4" & xrestr & xroute
  $rDatax = modDatabase.$myConn.Exec(sql1 & " UNION ALL " & sql2, encid, "Continue", False, 0, modDate.StartSqlDate(Now()))                 ''
  $aMyFieldsx = New String[]
  modGridView.ReadSmallData(ListView1, $rDatax, $aMyFieldsx)
  With ListView1
    .Columns[0].Width = 1
    .Columns[1].Width = 25 * modBasic.$AppWidthRatio
    .Columns[2].Width = 300 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[6].Width = 1

    .Columns[2].Text = "Medicine"
    .Columns[3].Text = "Regimen"
    .Columns[4].Text = "Doctor"
    .Columns[5].Text = "Location"
  End With

End

Public Sub ListView1_Data(Row As Integer, Column As Integer)

  $rDatax.MoveTo(Row)
  modGeneralMain.GridViewDecoration(ListView1, Row)
  If Column = 1 Then
    ListView1.Data.Picture = Picture["icons/unchecked.png"]
    ListView1.Data.Text = ""
  Else If Column = 3 Then
    ListView1.Data.Text = GetRegimen($rDatax[$aMyFieldsx[Column]])
  Else
    ListView1.Data.Text = $rDatax[$aMyFieldsx[Column]]
  Endif
  ListView1.Rows[Row].Height = Max(ListView1.Rows[Row].Height, ListView1.Data.Font.RichTextHeight(ListView1.Data.Text, ListView1.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (ListView1.Rows.Height - ListView1.Font.Height))
  ListView1.Data.WordWrap = True

End

Private Function GetRegimen(sText As String) As String

  Dim asx As String[]
  Dim xx As String

  asx = Split(sText, "|")
  If asx.Count = 3 Then
    If asx[2] = "0" Then
      xx = asx[0] & " X " & asx[1]
    Else
      xx = asx[0] & " X " & asx[1] & " X " & asx[2]
    Endif
  Else
    xx = ""
  Endif
  Return xx

End

Public Sub ListView1_Click()

  Dim xtot As Float
  Dim xadmn As Float

  If ListView1.Column = 1 Then
    modGridView.CheckUncheckGridNoDB(ListView1, 1)
  Else
