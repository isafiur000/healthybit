    xadmn = modPharmacy.GetCardexAdministerQTY(ListView1[ListView1.Row, 6].Text, ListView1[ListView1.Row, 2].Text)
    txtbalance.Value = xtot - xadmn
  Endif

End

Public Sub chkaddall_Click()

  Dim Row As Integer

  For Row = 0 To ListView1.Rows.Count - 1
    If chkaddall.Value = True Then
      ListView1[Row, 1].Picture = Picture["icons/checked.png"]
    Else If chkaddall.Value = False Then
      ListView1[Row, 1].Picture = Picture["icons/unchecked.png"]
    Endif
  Next

End

Public Sub btnaddorder_Click()

  Dim Row As Integer
  Dim res As Result

  Dim xtax As Float
  Dim xdisc As Float
  Dim itemtype As String
  Dim xfixrate As Float
  Dim xfixname As String
  Dim itemmode As String
  Dim CPharmFix As CFixRatePharmacy
  Dim xgo As Boolean
  Dim xallow As Boolean
  Dim xflvool As Float
  Dim xflrate As Float

  Dim hForm As CPackageParams
  Dim xBillMode As String
  Dim xLedgerAC As String
  Dim xBillType As String
  Dim xsClaimState As String

  $HiCappingVar = New Collection
  hForm = New CPackageParams($encid, cmbnewscheme.Text)
  xBillMode = hForm.GetBillingMode()
  xLedgerAC = hForm.GetLedgerAC()
  xBillType = hForm.GetBillType()
  xsClaimState = hForm.GetClaimState()

  For Row = 0 To ListView1.Rows.Count - 1
    If ListView1[Row, 1].Picture = Picture["icons/checked.png"] Then
      res = modDatabase.$myConn.Exec("select fldid,fldroute,flditem,flddose,fldfreq,flddays,fldqtyorder,fldprescriber,fldregno,flddirection,fldadminsite,fldmixing,fldstarttime,fldendtime,fldmixvolume,fldmixrate from tblinpatdosing where fldencounterval=&1 and fldid=&2 and fldcurval=&3 and fldsave=&4", ListView1[Row, 6].Text, ListView1[Row, 0].Text, "Continue", False)                 ''
      If res.Available Then

        If res["fldmixvolume"] Then
          xflvool = res["fldmixvolume"]
        Else
          xflvool = 0
        Endif
        If res["fldmixrate"] Then
          xflrate = res["fldmixrate"]
        Else
          xflrate = 0
        Endif
        xallow = False
        If res["fldendtime"] >= modDate.StartSqlDate(Now()) Then
          xallow = True
        Else If res["flddays"] = 0 Then
          xallow = True
        Endif

        If xallow = True Then
          itemtype = modNonMedical.GetBillItemCategoryFromCombo(res["fldroute"])
          xgo = False
          If modBasic.$BillPharmFixedModes.Exist(xBillMode) = True Then
            CPharmFix = New CFixRatePharmacy(itemtype, res["flditem"], xBillMode)
            xfixrate = CPharmFix.GetFixRate()
            xfixname = CPharmFix.GetFixItem()
            If xfixname Then
              xgo = True
            Else
              xgo = False
            Endif
          Else
            xgo = True
          Endif

          If xgo = True Then
            itemmode = xBillMode
            xtax = modNonMedical.ShowTaxValues(itemtype, res["flditem"])
            xdisc = modNonMedical.DiscPercentForCategoryValue($encid, cmbnewscheme.Text, itemtype, res["flditem"], itemmode)
            modPharmSub.InsertDosingMedicine($encid, xBillType, xBillMode, cmbnewscheme.Text, xLedgerAC, res["fldroute"], res["flditem"], res["flddose"], res["fldfreq"], res["flddays"], res["fldqtyorder"], txtstatus.Text, res["fldprescriber"], res["fldregno"], Now(), xtax, xdisc, xfixname, xfixrate, "Request", "IPD", res["flddirection"], 0, res["fldid"], "Continue", res["fldadminsite"], res["fldmixing"], xflrate, xflvool)
          Endif
        Endif

      Endif
    Endif
  Next
  FillDispenstable($encid)

End

Private Function ExecuteQuery(encid As String) As Result

  Dim res As Result
  Dim xrestr As String
  Dim xList As String[]
  Dim i As Integer
  Dim xsql As String

  If $RestrictType And If $RestrictList.Count Then
    xList = $RestrictList.Copy()
    For i = 0 To xList.Count - 1
      xList[i] = "'" & xList[i] & "'"
    Next
    If $RestrictType = "Allow" Then
      xrestr = " and flditem IN(" & xList.Join(",") & ")"
    Else If $RestrictType = "Prevent" Then
      xrestr = " and flditem NOT IN(" & xList.Join(",") & ")"
    Endif
  Else
    xrestr = ""
  Endif

  If cmbdepart.Text Then
    xsql = db.Subst(" and fldencounterval in(select fldencounterval from tblencounter where fldcurrlocat in(select fldbed from tbldepartmentbed where flddept like &1))", cmbdepart.Text)
  Else
    xsql = ""
  Endif
  res = modDatabase.$myConn.Exec("select fldid,fldtime_order,fldroute,flditem,fldqtydisp,flddose,fldfreq,flddays,fldlabel,flddirection,fldcomp_order,fldencounterval,flditemtype,fldfixname,fldfixrate,fldtaxper,flddiscper,fldbillingmode,flddisctype,fldacledger,fldbilltype,fldcashincredit,flditemno from tblpatdosing where fldencounterval=&1 and fldlevel=&2 and flditemtype like &3 and fldcurval=&4 and fldqtydisp>&5 and fldstatus=&6 and fldsave_order=&7" & xrestr & xsql, encid, "Requested", "%", "Continue", 0, "Admitted", False)

  Return res

End

Private Sub FillDispenstable(encid As String)

  $rData2 = ExecuteQuery(encid)
  $aMyFields2 = New String[]
  modGridView.ReadSmallData(GridView2, $rData2, $aMyFields2)

  With GridView2
    .Columns[0].Width = 1
    .Columns[1].Width = 135 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 350 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    If chkregimen.Value = True Then
      .Columns[5].Width = 75 * modBasic.$AppWidthRatio
      .Columns[6].Width = 50 * modBasic.$AppWidthRatio
      .Columns[7].Width = 50 * modBasic.$AppWidthRatio
      .Columns[8].Width = 25 * modBasic.$AppWidthRatio
    Else
      .Columns[5].Width = 1
      .Columns[6].Width = 1
      .Columns[7].Width = 1
      .Columns[8].Width = 1
    Endif

    .Columns[9].Width = 200 * modBasic.$AppWidthRatio
    .Columns[10].Width = 1
    .Columns[11].Width = 1
    .Columns[12].Width = 1

    .Columns[13].Width = 1
    .Columns[14].Width = 1
    .Columns[15].Width = 1
    .Columns[16].Width = 1
    .Columns[17].Width = 1
    .Columns[18].Width = 125 * modBasic.$AppWidthRatio
    .Columns[19].Width = 1
    .Columns[20].Width = 1
    .Columns[21].Width = 1
    .Columns[22].Width = 1 ''cardex no

    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Route"
    .Columns[3].Text = "Particulars"
    .Columns[4].Text = "QTY"
    If chkregimen.Value = True Then
      .Columns[5].Text = "Dose"
      .Columns[6].Text = "Freq"
      .Columns[7].Text = "Day"
    Endif
    .Columns[9].Text = "Direction"
    .Columns[18].Text = "Scheme"
  End With

End

Public Sub GridView2_Data(Row As Integer, Column As Integer)

  $rData2.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView2, Row)
  If Column = 1 Then
    GridView2.Data.Text = modReportVar.GetDateTimeReport($rData2[$aMyFields2[Column]], gb.GeneralDate)
  Else If Column = 8 Then
    GridView2.Data.Picture = Picture[modMisc.SetGridCheckIcon($rData2["fldlabel"])]
    GridView2.Data.Text = ""
  Else
    GridView2.Data.Text = $rData2[$aMyFields2[Column]]
  Endif
  GridView2.Rows[Row].Height = Max(GridView2.Rows[Row].Height, GridView2.Data.Font.RichTextHeight(GridView2.Data.Text, GridView2.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (GridView2.Rows.Height - GridView2.Font.Height))
  GridView2.Data.WordWrap = True

End

Public Sub GridView2_Click()

  Dim xval As Float
  Dim yval As String
  Dim col As Integer
  Dim row As Integer

  col = GridView2.Column
  row = GridView2.Row
  If GridView2.Column = 8 Then
    If GridView2[GridView2.Row, 12].Text = "Medicines" Then
      If GridView2[GridView2.Row, 4].Text And If GridView2[GridView2.Row, 5].Text And If GridView2[GridView2.Row, 6].Text Then
        modGridView.CheckUncheckGridWithDB(modDatabase.$myConn, GridView2, 8, "fldlabel", "fldid", "tblpatdosing", GridView2[GridView2.Row, 0].Text)
      Endif
    Endif

  Else If GridView2.Column = 4 Then
    xval = InputValue(GridView2[GridView2.Row, 3].Text, ("Alter Quantity"), GridView2[GridView2.Row, 4].Text)
    If xval > 0 Then
      modPharmSub.UpdateQTYBefDispensing(GridView2[GridView2.Row, 0].Text, xval)
      FillDispenstable($encid)
    Endif

  Else If GridView2.Column = 9 Then
    yval = InputBox(GridView2[GridView2.Row, 3].Text, ("Alter Direction"), GridView2[GridView2.Row, 9].Text)
    If yval Then
      modPharmSub.UpdateAdviceBefDispensing(GridView2[GridView2.Row, 0].Text, yval)
      FillDispenstable($encid)
    Endif

  Endif
  GridView2.Column = col
  GridView2.Row = row

End

Public Sub GridView2_Menu()

  mnuhide.Popup

End

Public Sub chkprintlabel_Click()

  modSettings.EnterCheckSetting(chkprintlabel, "DispensingList/PrintLabel")

End

Public Sub mnuremove_Click()

  If GridView2.Rows.Selection.Count > 0 Then
    modDatabase.$myConn.Delete("tblpatdosing", "fldid=&1 and fldsave_order=&2", GridView2[GridView2.Row, 0].Text, False)
    FillDispenstable($encid)
  Endif

End

Public Sub mnusaveout_Click()

  If GridView2.Rows.Selection.Count > 0 Then
    If Message.Question(("Bring from OUTSIDE. Are you sure ?"), ("No"), ("Yes")) = 2 Then
      modPharmSub.UpdateDispensing(GridView2[GridView2.Row, 0].Text, True)
      FillDispenstable($encid)
    Endif
  Endif

End

Public Sub btnclaerall_Click()

  PharmacySave()
  FillDispenstable($encid)
  ShowDispensedToday($encid)
  txtsearch.Text = ""
  txtsearch.SetFocus

End

