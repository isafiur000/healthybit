' Gambas class file

Private $sFormat As String

Private $ReportPath As String
Private ReportFile As File
Private $sDataVar As Variant[]

Public Sub _new(sFormat As String)

  $sFormat = sFormat

  If $sFormat = "CSV" Then
    $ReportPath = Temp() & ".csv"
    ReportFile = Open $ReportPath For Write Create
  Else
    $sDataVar = New Variant[]
    $ReportPath = Temp() & ".json"
  Endif

End

Public Sub Add(sArry As String[])

  If $sFormat = "CSV" Then
    Write #ReportFile, sArry.Join(gb.Tab) & gb.NewLine
  Else
    $sDataVar.Add(sArry)
  Endif

End

Public Function GetCSVFile() As String

  If $sFormat = "CSV" Then
    Close #ReportFile
  Else
    File.Save($ReportPath, JSON.Encode($sDataVar))
  Endif

  Return $ReportPath

End
