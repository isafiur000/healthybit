# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,105,64)
  Text = ("PACS Images")
  Resizable = False
  { GridView3 GridView
    MoveScaled(1,9,32,46)
    Mode = Select.Single
    Header = GridView.Horizontal
  }
  { Panel1 Panel
    MoveScaled(34,58,70,5)
    { Slider1 Slider
      MoveScaled(7,1,49,4)
      MinValue = 1
      MaxValue = 1000
      Value = 150
    }
    { btnnext Button
      MoveScaled(64,1,5,4)
      Picture = Picture["icon:/small/right"]
    }
    { btnprev Button
      MoveScaled(0,0.625,4.875,4)
      Picture = Picture["icon:/small/left"]
    }
    { SpinBox1 SpinBox
      MoveScaled(58,1,5,3)
      MinValue = 1
      Value = 1
    }
  }
  { ScrollView1 ScrollView
    MoveScaled(34,1,70,56)
    { pictimage ImageView
      MoveScaled(1,1,68,54)
    }
  }
  { Panel2 Panel
    MoveScaled(13,1,20,3)
    { rbdicom RadioButton
      MoveScaled(10,0,10,3)
      Text = ("DICOM")
      Value = True
    }
    { rbimage RadioButton
      MoveScaled(0,0,10,3)
      Text = ("IMAGE")
    }
  }
  { chkanony CheckBox
    MoveScaled(1,1,11,3)
    Text = ("Anonym")
  }
  { btnexec Button
    MoveScaled(12,5,10,3)
    Text = ("View")
    Picture = Picture["icon:/small/exec"]
  }
  { btnsave Button
    MoveScaled(1,5,10,3)
    Text = ("Save")
    Picture = Picture["icon:/small/save"]
  }
  { btndowb Button
    MoveScaled(23,5,10,3)
    Text = ("Edit")
    Picture = Picture["icon:/small/edit"]
  }
  { TextBox1 TextBox
    MoveScaled(1,56,28,3)
    ReadOnly = True
  }
  { btncopy ToolButton
    MoveScaled(29,56,4,3)
    Picture = Picture["icon:/small/copy"]
  }
  { btnanalyze Button
    MoveScaled(1,59.5,32,4)
    Text = ("Analyze")
  }
}
