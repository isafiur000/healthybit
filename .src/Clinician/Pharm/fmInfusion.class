' Gambas class file

Private $encid As String
Private $useCardex As Boolean

Private $rFludRes As Result
Private $aFludFields As String[]
Private $rRateRes As Result
Private $aRateFields As String[]

Private $rMixRes As Result
Private $aMixFields As String[]

Public Sub _new(encid As String, useCardex As Boolean)

  $encid = encid
  $useCardex = useCardex

End

Public Sub Form_Open()

  ShowMedFluids()
  If $useCardex = True Then
    ShowMixtureFluids()
  Endif

End

Public Sub RefreshTables()

  ShowMedFluids()
  If $useCardex = True Then
    ShowMixtureFluids()
  Endif

End

Public Sub SetEntryOrder(sBool As Boolean)

  grdfluid.Enabled = sBool
  grdfluiddata.Enabled = sBool
  If $useCardex = True Then
    pnlmixture.Enabled = sBool
  Endif

End

Public Sub chkalldate_Click()

  ShowMedFluids()

End

Private Sub ShowMedFluids()

  Dim xFields As String[]
  Dim sql As String
  Dim sql1 As String
  Dim sql2 As String
  Dim xrouLst As String[] = ["fluid", "CIV", "CIn(Epid)", "CIn(Block)"]
  Dim j As Integer

  For j = 0 To xrouLst.Count - 1
    xrouLst[j] = "'" & xrouLst[j] & "'"
  Next

  If $useCardex = True Then
    xFields = ["fldid", "fldid", "CONCAT(flditem, '|', COALESCE(fldmixing, ''))", "CONCAT(flditem, '|', flddose)", "fldfreq", "flddays", "fldstarttime", "fldcurval", "fldstarttime", "fldcurval", "fldendtime", "flddirection", "fldadminsite", "fldmixing", "fldroute", "flditem", "fldmixvolume", "fldmixrate", "flddose"]
  Else
    xFields = ["fldid", "fldid", "CONCAT(flditem, '|', COALESCE(fldmixing, ''))", "CONCAT(flditem, '|', flddose)", "fldfreq", "flddays", "fldstarttime", "fldcurval", "fldstarttime", "fldstatus", "fldendtime", "flddirection", "fldadminsite", "fldmixing", "fldroute", "flditem", "fldmixvolume", "fldmixrate", "flddose"]
  Endif

  If $useCardex = True Then
    If chkalldate.Value = True Then
      sql = "select " & xFields.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&3 and (fldmixing IS NULL or fldmixing NOT LIKE &4)"
      $rFludRes = modDatabase.$myConn.Exec(sql, $encid, "Continue", 0, "ADMIXTURE:" & "%")
    Else
      sql1 = "select " & xFields.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&2 and flddose>&3 and flddays>&3 and (fldmixing IS NULL or fldmixing NOT LIKE &4) and fldstarttime<=&5 and fldendtime>=&6"
      sql2 = "select " & xFields.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&3 and flddays=&3 and (fldmixing IS NULL or fldmixing NOT LIKE &4)"
      $rFludRes = modDatabase.$myConn.Exec(sql1 & " UNION " & sql2, $encid, "Continue", 0, "ADMIXTURE:" & "%", Now(), DateAdd(Now(), gb.Hour, -3))
    Endif
  Else
    If chkalldate.Value = True Then
      sql = "select " & xFields.Join(",") & " from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&4 and (fldmixing IS NULL or fldmixing NOT LIKE &5) ORDER BY fldstarttime DESC"
      $rFludRes = modDatabase.$myConn.Exec(sql, $encid, True, "Continue", 0, "ADMIXTURE:" & "%")
    Else
      sql = "select " & xFields.Join(",") & " from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&4 and (fldmixing IS NULL or fldmixing NOT LIKE &5) and fldstarttime<=&6 and fldendtime>=&7 ORDER BY fldstarttime DESC"
      $rFludRes = modDatabase.$myConn.Exec(sql, $encid, True, "Continue", 0, "ADMIXTURE:" & "%", modDate.EndSqlDate(Now()), modDate.StartSqlDate(Now()))
    Endif
  Endif
  $aFludFields = New String[]
  modGridView.ReadSmallData(grdfluid, $rFludRes, $aFludFields)

  With grdfluid
    .Columns[0].Width = 1
    .Columns[1].Width = 35 * modBasic.$AppWidthRatio
    .Columns[2].Width = Max(Me.Width / 2, 400 * modBasic.$AppWidthRatio)
    .Columns[3].Width = 75 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 100 * modBasic.$AppWidthRatio
    .Columns[8].Width = 1 ''start time
    .Columns[9].Width = 1
    .Columns[10].Width = 1 ''end time
    .Columns[11].Width = 1 ''direction
    .Columns[12].Width = 1 ''admin site
    .Columns[13].Width = 1 ''dilution
    .Columns[14].Width = 1  ''route
    .Columns[15].Width = 1 ''Item name
    .Columns[16].Width = 1 ''Mix Volume
    .Columns[17].Width = 75 * modBasic.$AppWidthRatio
    .Columns[18].Width = 1 ''dose

    .Columns[2].Text = "Medicine"
    .Columns[3].Text = "Dose"
    .Columns[4].Text = "Freq"
    .Columns[5].Text = "Days"
    .Columns[6].Text = "Date"
    .Columns[7].Text = "Status"
    .Columns[17].Text = "mL/Hour"
  End With

End

Public Sub grdfluid_Data(Row As Integer, Column As Integer)

  $rFludRes.MoveTo(Row)
  modGeneralMain.GridViewDecoration(grdfluid, Row)
  If Column = 1 Then
    grdfluid.Data.Picture = Picture[GetFluidAdminStatusCode($rFludRes[$aFludFields[Column]])]
    grdfluid.Data.Text = ""
  Else If Column = 2 Then
    grdfluid.Data.RichText = GetInjectionName($rFludRes[$aFludFields[Column]])
  Else If Column = 3 Then
    grdfluid.Data.Text = GetMedicineDose($rFludRes[$aFludFields[Column]])
  Else If Column = 6 Then
    grdfluid.Data.Text = modReportVar.GetDateTimeReport($rFludRes[$aFludFields[Column]], gb.GeneralDate)
  Else
    grdfluid.Data.Text = $rFludRes[$aFludFields[Column]]
  Endif
  grdfluid.Rows[Row].Height = Max(grdfluid.Rows[Row].Height, grdfluid.Data.Font.RichTextHeight(grdfluid.Data.RichText, grdfluid.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (grdfluid.Rows.Height - grdfluid.Font.Height))
  grdfluid.Data.WordWrap = True

End

Private Function GetInjectionName(sItem As String) As String

  Dim asx As String[]
  Dim xx As String

  asx = Split(sItem, "|")
  If asx.Count = 2 Then
    If Trim(asx[1]) Then
      xx = asx[0] & " <small>[" & asx[1] & "]</small>"
    Else
      xx = asx[0]
    Endif
  Else
    xx = asx[0]
  Endif

  Return xx

End

Private Function GetMedicineDose(sItem As String) As String

  Dim asx As String[]
  Dim xx As String

  asx = Split(sItem, "|")
  If asx.Count = 2 Then
    xx = asx[1] & Space(1) & modMedConstant.GetMedicineDoseUnit(asx[0])
  Else
    xx = ""
  Endif

  Return xx

End

Public Sub btndirection_Click()

  If grdfluid.Rows.Selection.Count Then
    lblduration.Text = grdfluid[grdfluid.Row, 11].Text
  Endif

End

Public Sub btnfluid_Click()

  If grdfluid.Rows.Selection.Count Then
    lblduration.Text = grdfluid[grdfluid.Row, 13].Text & "  Volume: " & grdfluid[grdfluid.Row, 16].Text & " mL"
  Endif

End

Public Sub btnprotocol_Click()

  Dim res As Result
  Dim hForm As FmInjection

  If grdfluid.Rows.Selection.Count Then
    res = modDatabase.$medConn.Exec("select fldlabel from tbllabel where flddrug=&1 and fldsubroute=&2", modMedConstant.GetDrugFromStockID(grdfluid[grdfluid.Row, 15].Text), grdfluid[grdfluid.Row, 14].Text)
    If res.Available Then
      res.MoveFirst
      hForm = New FmInjection(grdfluid[grdfluid.Row, 14].Text, res["fldlabel"])
      hForm.ShowModal
    Endif
  Endif

End

Private Function GetDateTimeLabel(dt1 As Date, dt2 As Date) As String

  Dim xx As String

  If dt2 Then
    If modDate.StartSqlDate(dt1) = modDate.StartSqlDate(dt2) Then
      xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate) & " TO " & modReportVar.GetDateTimeReport(dt2, gb.MediumTime)
    Else
      xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate) & " TO " & modReportVar.GetDateTimeReport(dt2, gb.GeneralDate)
    Endif
  Else
    xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate)
  Endif
  Return xx

End

Public Sub btntime_Click()

  If grdfluid.Rows.Selection.Count Then
    lblduration.Text = GetDateTimeLabel(grdfluid[grdfluid.Row, 8].Text, grdfluid[grdfluid.Row, 10].Text)
  Endif

End

Public Sub grdfluid_Click()

  Dim xx As String[] = ["Continue", "Discontinue", "On Hold", "Cancelled"]
  Dim res As Result
  Dim xval As String
  Dim yval As Integer
  Dim Row As Integer

  Row = grdfluid.Row
  FillFluidGridView(grdfluid[grdfluid.Row, 0].Text)
  lblduration.Text = grdfluid[grdfluid.Row, 11].Text
  If grdfluid.Column = 7 Then
    If $useCardex = False Then
      xval = InputCombo(grdfluid[grdfluid.Row, 15].Text, ("Select Current Status"), xx, grdfluid[grdfluid.Row, 7].Text, True)
      If xval Then
        res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1", grdfluid[grdfluid.Row, 0].Text)
        res["fldcurval"] = xval
        res["xyz"] = False
        res.Update()
        ShowMedFluids()
      Endif
    Endif

  Else If grdfluid.Column = 1 Then
    If grdfluid[grdfluid.Row, 7].Text = "Continue" Then
      If grdfluid[grdfluid.Row, 1].Picture = Picture["icon:/tiny/next"] Then
        yval = InputValue(("Enter Rate of Administration in ") & "<b>mL/Hour</b> FOR <b>" & grdfluid[grdfluid.Row, 15].Text & "</b>", "Administration Rate", 0)
        If yval Then
          If $useCardex = True Then
            modPharmSub.InsertNurDosingIndoor($encid, 0, grdfluid[grdfluid.Row, 0].Text, yval, "mL/Hour", grdfluid[grdfluid.Row, 15].Text, grdfluid[grdfluid.Row, 18].Text, grdfluid[grdfluid.Row, 4].Text, Now())
          Else
            modPharmSub.InsertNurDosingIndoor($encid, grdfluid[grdfluid.Row, 0].Text, 0, yval, "mL/Hour", grdfluid[grdfluid.Row, 15].Text, grdfluid[grdfluid.Row, 18].Text, grdfluid[grdfluid.Row, 4].Text, Now())
          Endif
          FillFluidGridView(grdfluid[grdfluid.Row, 0].Text)
          ShowMedFluids()
        Endif
      Endif
    Endif

  Else If grdfluid.Column = 17 Then
    If $useCardex = False Then
      yval = InputValue(("Enter New Rate of Administration in ") & "<b>mL/Hour</b> FOR <b>" & grdfluid[grdfluid.Row, 15].Text & "</b>", "Administration Rate", grdfluid[grdfluid.Row, 17].Text)
      If yval Then
        res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1", grdfluid[grdfluid.Row, 0].Text)
        res["fldmixrate"] = yval
        res["xyz"] = False
        res.Update()
        ShowMedFluids()
      Endif
    Endif

  Endif
  grdfluid.Row = Row

End

Private Sub FillFluidGridView(dosno As Long)

  If $useCardex = True Then
    $rRateRes = modDatabase.$myConn.Exec("select fldid,fldmedicine,fldvalue,fldunit,fldid,fldfromtime,fldtotime,fldcardex from tblnurdosing where fldencounterval=&1 and fldcardex=&2 and fldfromtime IS NOT NULL ORDER BY fldid DESC", $encid, dosno)
  Else
    $rRateRes = modDatabase.$myConn.Exec("select fldid,fldmedicine,fldvalue,fldunit,fldid,fldfromtime,fldtotime,flddoseno from tblnurdosing where fldencounterval=&1 and flddoseno=&2 and fldfromtime IS NOT NULL ORDER BY fldid DESC", $encid, dosno)
  Endif
  $aRateFields = New String[]
  modGridView.ReadSmallData(grdfluiddata, $rRateRes, $aRateFields)

  With grdfluiddata
    .Columns[0].Width = 1
    .Columns[1].Width = Max(Me.Width / 2, 400 * modBasic.$AppWidthRatio)
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 40 * modBasic.$AppWidthRatio
    .Columns[5].Width = 150 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 1

    .Columns[1].Text = "Particulars"
    .Columns[2].Text = "Rate"
    .Columns[3].Text = "Unit"
    .Columns[5].Text = "Start"
    .Columns[6].Text = "Close"
  End With

End

Public Sub grdfluiddata_Data(Row As Integer, Column As Integer)

  $rRateRes.MoveTo(Row)
  modGeneralMain.GridViewDecoration(grdfluiddata, Row)
  If Column = 2 Then
    grdfluiddata.Data.Text = $rRateRes[$aRateFields[Column]]
    grdfluiddata.Data.Alignment = Align.Right
  Else If Column = 4 Then
    grdfluiddata.Data.Picture = Picture[GetPictureDosing($rRateRes[$aRateFields[Column]])]
  Else If Column = 5 Then
    grdfluiddata.Data.Text = modReportVar.GetDateTimeReport($rRateRes[$aRateFields[Column]], gb.GeneralDate)
  Else If Column = 6 Then
    grdfluiddata.Data.Text = modReportVar.GetDateTimeReport($rRateRes[$aRateFields[Column]], gb.GeneralDate)
  Else
    grdfluiddata.Data.Text = $rRateRes[$aRateFields[Column]]
  Endif

End

Public Sub grdfluiddata_Click()

  Dim res As Result
  Dim Row As Integer

  If grdfluiddata.Column = 4 Then
    If grdfluiddata[grdfluiddata.Row, 4].Picture = Picture["icon:/tiny/stop"] Then
      Row = grdfluid.Row
      res = modDatabase.$myConn.Edit("tblnurdosing", "fldid=&1 and fldencounterval=&2", grdfluiddata[grdfluiddata.Row, 0].Text, $encid)
      res["fldtotime"] = Now()
      res["xyz"] = False
      res.Update
      FillFluidGridView(grdfluiddata[grdfluiddata.Row, 7].Text)
      ShowMedFluids()
      grdfluid.Row = Row
    Endif
  Endif

End

Private Function GetPictureDosing(dosid As Long) As String

  Dim res As Result
  Dim xx As String

  res = modDatabase.$myConn.Exec("select flddoseno,fldfromtime,fldtotime from tblnurdosing where fldid=&1", dosid)
  If res.Available Then
    res.MoveFirst
    If res["fldfromtime"] And If Not res["fldtotime"] Then
      xx = "icon:/tiny/stop"
    Else If res["fldfromtime"] And If res["fldtotime"] Then
      xx = "icon:/tiny/lock"
    Endif
  Endif
  Return xx

End

Private Function GetFluidAdminStatusCode(dosno As Long) As String

  Dim res As Result
  Dim xx As String

  If $useCardex = True Then
    res = modDatabase.$myConn.Exec("select fldid,fldfromtime,fldtotime from tblnurdosing where fldencounterval=&1 and fldcardex=&2 ORDER BY fldid DESC", $encid, dosno)
  Else
    res = modDatabase.$myConn.Exec("select fldid,fldfromtime,fldtotime from tblnurdosing where fldencounterval=&1 and flddoseno=&2 ORDER BY fldid DESC", $encid, dosno)
  Endif
  If res.Available Then
    res.MoveFirst
    If res["fldfromtime"] And If Not res["fldtotime"] Then
      xx = "icon:/tiny/stop"
    Else
      xx = "icon:/tiny/next"
    Endif
  Else
    xx = "icon:/tiny/next"
  Endif
  Return xx

End

''================================= Admixture =============================
Public Sub chkmixall_Click()

  If $useCardex = True Then
    ShowMixtureFluids()
  Endif

End

Private Sub ShowMixtureFluids()

  Dim xFields As String[]
  Dim sql As String
  Dim sql1 As String
  Dim sql2 As String
  Dim res As Result
  Dim rsx As Result
  Dim xrouLst As String[] = ["fluid", "CIV", "CIn(Epid)", "CIn(Block)"]
  Dim j As Integer

  Dim Column As Integer
  Dim fld As ResultField

  Dim pic2 As Picture

  If $useCardex = True Then
    xFields = ["flditem", "CONCAT(flditem, '|', flddose)", "fldfreq", "flddays", "fldstarttime", "fldcurval", "fldstarttime", "fldcurval", "fldendtime", "flddirection", "fldadminsite", "fldmixing", "fldroute", "flditem", "fldmixvolume", "fldmixrate", "fldid"]
  Endif

  ColumnView1.Clear
  ColumnView1.Columns.Count = xFields.Count
  With ColumnView1
    .Columns[0].Width = Max(Me.Width / 2, 400 * modBasic.$AppWidthRatio)
    .Columns[1].Width = 75 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 50 * modBasic.$AppWidthRatio
    .Columns[4].Width = 150 * modBasic.$AppWidthRatio
    .Columns[5].Width = 100 * modBasic.$AppWidthRatio
    .Columns[6].Width = 1 ''start time
    .Columns[7].Width = 1
    .Columns[8].Width = 1 ''end time
    .Columns[9].Width = 1 ''direction
    .Columns[10].Width = 1 ''admin site
    .Columns[11].Width = 1 ''dilution
    .Columns[12].Width = 1  ''route
    .Columns[13].Width = 1 ''Item name
    .Columns[14].Width = 1 ''Mix Volume
    .Columns[15].Width = 75 * modBasic.$AppWidthRatio
    .Columns[16].Width = 1  ''fldid

    .Columns[0].Text = "Medicine"
    .Columns[1].Text = "Dose"
    .Columns[2].Text = "Freq"
    .Columns[3].Text = "Days"
    .Columns[4].Text = "Date"
    .Columns[5].Text = "Status"
    .Columns[15].Text = "mL/Hour"
  End With

  For j = 0 To xrouLst.Count - 1
    xrouLst[j] = "'" & xrouLst[j] & "'"
  Next

  If $useCardex = True Then
    If chkmixall.Value = True Then
      sql = "select distinct(fldmixing) as fldmixing from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&3 and fldmixing LIKE &4"
      rsx = modDatabase.$myConn.Exec(sql, $encid, "Continue", 0, "ADMIXTURE:" & "%")
    Else
      sql1 = "select distinct(fldmixing) as fldmixing from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&2 and flddose>&3 and flddays>&3 and fldmixing LIKE &4 and fldstarttime<=&5 and fldendtime>=&6"
      sql2 = "select distinct(fldmixing) as fldmixing from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&3 and flddays=&3 and fldmixing LIKE &4"
      rsx = modDatabase.$myConn.Exec(sql1 & " UNION " & sql2, $encid, "Continue", 0, "ADMIXTURE:" & "%", Now(), DateAdd(Now(), gb.Hour, -3))
    Endif
  Endif
  If rsx.Available Then
    For Each rsx
      ColumnView1.Add(rsx["fldmixing"], rsx["fldmixing"])

      If $useCardex = True Then
        If chkmixall.Value = True Then
          sql = "select " & xFields.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&3 and fldmixing=&4"
          res = modDatabase.$myConn.Exec(sql, $encid, "Continue", 0, rsx["fldmixing"])
        Else
          sql1 = "select " & xFields.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&2 and flddose>&3 and flddays>&3 and fldmixing=&4 and fldstarttime<=&5 and fldendtime>=&6"
          sql2 = "select " & xFields.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&3 and flddays=&3 and fldmixing=&4"
          res = modDatabase.$myConn.Exec(sql1 & " UNION " & sql2, $encid, "Continue", 0, rsx["fldmixing"], Now(), DateAdd(Now(), gb.Hour, -3))
        Endif
      Endif
      If res.Available Then
        res.MoveFirst
        pic2 = Picture[GetFluidAdminStatusCode(res["fldid"])]
        ColumnView1[rsx["fldmixing"]].Picture = pic2

        For Each res
          ColumnView1.Add(rsx["fldmixing"] & "@" & CStr(res["fldid"]), res["fldid"], pic2, rsx["fldmixing"])
          Column = 0
          For Each fld In res.Fields
            If Column = 1 Then
              ColumnView1[rsx["fldmixing"] & "@" & CStr(res["fldid"])][Column] = GetMedicineDose(res[fld.Name])
            Else
              ColumnView1[rsx["fldmixing"] & "@" & CStr(res["fldid"])][Column] = res[fld.Name]
            Endif
            Column = Column + 1
          Next
        Next
      Endif

    Next
  Endif

End

Private Sub ResetButtons()

  If ColumnView1.Current.Picture = Picture["icon:/tiny/next"] Then
    btnmixstart.Enabled = True
    btnmixclose.Enabled = False
  Else
    btnmixstart.Enabled = False
    btnmixclose.Enabled = True
  Endif

End

Public Sub ColumnView1_Click()

  If ColumnView1.Current.Key = ColumnView1.Current.Text Then
    txtmixture.Text = ColumnView1.Current.Key
    ResetButtons()

  Else
    txtmixture.Text = ""
    btnmixstart.Enabled = False
    btnmixclose.Enabled = False
  Endif
  FillMixtureGridView(txtmixture.Text)

End

Public Sub btnmixstart_Click()

  Dim res As Result
  Dim xrouLst As String[] = ["fluid", "CIV", "CIn(Epid)", "CIn(Block)"]
  Dim j As Integer

  For j = 0 To xrouLst.Count - 1
    xrouLst[j] = "'" & xrouLst[j] & "'"
  Next

  If ColumnView1.Selection.Count Then
    If txtmixrate.Value > 0 Then
      If ColumnView1.Current.Picture = Picture["icon:/tiny/next"] Then

        If $useCardex = True Then
          res = modDatabase.$myConn.Exec("select fldid,flditem,flddose,fldfreq from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&2 and flddose>&3 and fldmixing=&4", $encid, "Continue", 0, txtmixture.Text)
          If res.Available Then
            For Each res
              If $useCardex = True Then
                modPharmSub.InsertNurDosingIndoor($encid, 0, res["fldid"], txtmixrate.Value, "mL/Hour", res["flditem"], res["flddose"], res["fldfreq"], Now())
              Endif
            Next
            FillMixtureGridView(txtmixture.Text)
            ResetButtons()
            ShowMixtureFluids()
          Endif
        Endif

      Endif
    Endif
  Endif

End

Private Sub FillMixtureGridView(xMixture As String)

  If $useCardex = True Then
    $rMixRes = modDatabase.$myConn.Exec("select t1.fldid,t1.fldmedicine,t1.fldvalue,t1.fldunit,t1.fldid,t1.fldfromtime,t1.fldtotime,t1.fldcardex from tblnurdosing as t1 inner join tblinpatdosing as t2 on (t1.fldcardex=t2.fldid and t1.fldencounterval=t2.fldencounterval) where t1.fldencounterval=&1 and t1.fldfromtime IS NOT NULL and t2.fldmixing=&2  ORDER BY t1.fldid DESC", $encid, xMixture)
  Endif
  $aMixFields = New String[]
  modGridView.ReadSmallData(grdmixture, $rMixRes, $aMixFields)

  With grdmixture
    .Columns[0].Width = 1
    .Columns[1].Width = Max(Me.Width / 2, 400 * modBasic.$AppWidthRatio)
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 40 * modBasic.$AppWidthRatio
    .Columns[5].Width = 150 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 1

    .Columns[1].Text = "Particulars"
    .Columns[2].Text = "Rate"
    .Columns[3].Text = "Unit"
    .Columns[5].Text = "Start"
    .Columns[6].Text = "Close"
  End With

End

Public Sub grdmixture_Data(Row As Integer, Column As Integer)

  $rMixRes.MoveTo(Row)
  modGeneralMain.GridViewDecoration(grdmixture, Row)
  If Column = 2 Then
    grdmixture.Data.Text = $rMixRes[$aMixFields[Column]]
    grdmixture.Data.Alignment = Align.Right
  Else If Column = 4 Then
    grdmixture.Data.Picture = Picture[GetPictureDosing($rMixRes[$aMixFields[Column]])]
  Else If Column = 5 Then
    grdmixture.Data.Text = modReportVar.GetDateTimeReport($rMixRes[$aMixFields[Column]], gb.GeneralDate)
  Else If Column = 6 Then
    grdmixture.Data.Text = modReportVar.GetDateTimeReport($rMixRes[$aMixFields[Column]], gb.GeneralDate)
  Else
    grdmixture.Data.Text = $rMixRes[$aMixFields[Column]]
  Endif

End

Public Sub btnmixclose_Click()

  Dim res As Result
  Dim Row As Integer

  If ColumnView1.Selection.Count Then
    If ColumnView1.Current.Picture = Picture["icon:/tiny/stop"] Then
      For Row = 0 To grdmixture.Rows.Count - 1
        res = modDatabase.$myConn.Edit("tblnurdosing", "fldid=&1 and fldencounterval=&2", grdmixture[Row, 0].Text, $encid)
        res["fldtotime"] = Now()
        res["xyz"] = False
        res.Update
      Next
      FillMixtureGridView(txtmixture.Text)
      ResetButtons()
      ShowMixtureFluids()
    Endif
  Endif

End
