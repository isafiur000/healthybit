Public Sub mnueditdays_Click()

  Dim xval As Float
  Dim res As Result

  If modGeneral.AllowClinicalEdit(ColumnView1[ColumnView1.Current.Key][13]) = True Then
    xval = InputValue(ColumnView1[ColumnView1.Current.Key][0], ("Alter Duration"), ColumnView1[ColumnView1.Current.Key][4])
    If xval >= 0 Then
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", CLong(ColumnView1[ColumnView1.Current.Key][7]), $encid)
      res["flddays"] = xval
      If xval Then
        res["fldendtime"] = DateAdd(res["fldstarttime"], gb.Hour, CInt(xval * 24))
      Endif
      res["xyz"] = False
      res.Update
      ShowAdmixtures()
    Endif
  Endif

End

Public Sub mnueditdirection_Click()

  Dim yval As String
  Dim res As Result

  If modGeneral.AllowClinicalEdit(ColumnView1[ColumnView1.Current.Key][13]) = True Then
    yval = GetTextArea(ColumnView1[ColumnView1.Current.Key][0], ColumnView1[ColumnView1.Current.Key][11])
    If yval Then
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", CLong(ColumnView1[ColumnView1.Current.Key][7]), $encid)
      res["flddirection"] = Trim(yval)
      res["xyz"] = False
      res.Update
      ShowAdmixtures()
    Endif
  Endif

End

''==================== drug errors =====================
Private Sub GetMedErrorParameters()

  If modMedError.$PregnancyPrecaution = "No" Then
  Else
    $pregstat = modPatient.GetPregnancyStatus($encid)
  Endif
  If modMedError.$HepaticPrecaution = "No" Then
  Else
    $hepstat = modClinic.GetHepaticStatus($encid)
  Endif
  If modMedError.$RenalPrecaution = "No" Then
  Else
    $cretclr = modSysCons.GetCreatinineClearance($encid)
  Endif
  If modMedError.$AntibioticResistance = "No" Then
  Else
    $ResistDrugs = modLabTest.GetResistantAntibiotics($encid)
  Endif
  If modMedError.$AgeContraindication = "No" And If modMedError.$PreservativePrecaution = "No" Then
  Else
    $dtbir = modPatient.GetPatientBirthDay($encid)
    $dtrec = modPatient.GetRecordDate($encid)
  Endif
  If modMedError.$DrugAllergy = "No" Then
  Else
    $sAllerList = modControlSub.GetDirectFillresult(modDatabase.$myConn.Exec("select distinct(t1.fldcode) as col from tblpatfindings as t1 inner join tblencounter as t2 on t1.fldencounterval=t2.fldencounterval where t1.fldtype=&1 and t2.fldpatientval=&2 and fldsave=&3", "Allergic Drugs", $PatientNum, True))
  Endif

  If modMedError.$DiseaseContraindication = "Yes" Or If modMedError.$SideEffects = "Yes" Then
    $diagnosisList = modControlSub.GetDirectFillresult(modDatabase.$myConn.Exec("select distinct(fldcode) as col from tblpatfindings where fldencounterval=&1 and (fldtype=&2 or fldtype=&3) and fldsave=&4", $encid, "Final Diagnosis", "Provisional Diagnosis", True))
  Endif
  If modMedError.$LaboratoryInteraction = "Yes" Then
    $hypoTestList = modLabTest.GetHypoTestList($encid)
    $hyperTestList = modLabTest.GetHyperTestList($encid)
  Endif
  If modMedError.$ExaminationInteraction = "Yes" Then
    $bradyExamList = modClinic.GetBradyExamList($encid)
    $tachyExamList = modClinic.GetTachyExamList($encid)
  Endif
  If modMedError.$PreAdminMonitor = "Yes" Then
    $donelablist = modLabTest.PaientAllTestNameArray($encid)
  Endif

End

Private Sub GetReviewMultiMessage(sType As String)

  Dim xVar As Variant[]
  Dim xColl As Collection
  Dim cForm As CCheckErrors
  Dim xmsg As String

  If $rData.Available Then
    xVar = New Variant[]
    For Each $rData
      xColl = New Collection
      xColl.Add($rData["fldroute"], "Route")
      xColl.Add($rData["flditem"], "Medicine")
      xColl.Add($rData["flddose"], "Dose")
      xColl.Add($rData["fldfreq"], "Frequency")
      xVar.Add(xColl)
    Next

    cForm = New CCheckErrors($encid, xVar)
    If modMedError.$PregnancyPrecaution = "No" Then
    Else
      cForm.SetPregnancyStatus($pregstat)
    Endif
    If modMedError.$HepaticPrecaution = "No" Then
    Else
      cForm.SetHepaticStatus($hepstat)
    Endif
    If modMedError.$RenalPrecaution = "No" Then
    Else
      cForm.SetRenalStatus($cretclr)
    Endif
    If modMedError.$AntibioticResistance = "No" Then
    Else
      cForm.SetDrugResistance($ResistDrugs)
    Endif
    If modMedError.$AgeContraindication = "No" And If modMedError.$PreservativePrecaution = "No" Then
    Else
      cForm.SetPatientDates($dtbir, $dtrec)
    Endif
    If modMedError.$DrugAllergy = "No" Then
    Else
      cForm.SetAllergy($sAllerList)
    Endif

    If modMedError.$DiseaseContraindication = "Yes" Or If modMedError.$SideEffects = "Yes" Then
      cForm.SetDiagnosisList($diagnosisList)
    Endif
    If modMedError.$LaboratoryInteraction = "Yes" Then
      cForm.SetLabAbnormList($hypoTestList, $hyperTestList)
    Endif
    If modMedError.$ExaminationInteraction = "Yes" Then
      cForm.SetExamAbnormList($bradyExamList, $tachyExamList)
    Endif
    If modMedError.$PreAdminMonitor = "Yes" Then
      cForm.SetDoneLabList($donelablist)
    Endif

    If sType = "Message" Then
      Inc Application.Busy
      xmsg = cForm.GetMedErrorOutput()
      Dec Application.Busy
      If xmsg Then
        MessageView1.Close()
        MessageView1.Open(xmsg, Picture["icon:/small/info"])
      Endif

    Else If sType = "Report" Then
      Inc Application.Busy
      xmsg = modCHTMLPatient.ShowMedicationReviewCollectionHTML($encid, cForm.GetErrorColection())
      Dec Application.Busy
      modControlSub.OpenHTMLPreview($encid, xmsg, "ReportSize")
    Endif
  Endif

End
