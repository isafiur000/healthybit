  If ColumnView1.Current.Picture = Picture["icons/unchecked.png"] Then
    ColumnView1.Current.Picture = Picture["icons/checked.png"]
  Else If ColumnView1.Current.Picture = Picture["icons/checked.png"] Then
    ColumnView1.Current.Picture = Picture["icons/unchecked.png"]
  Endif

End

