Private Sub SetNarcoticsPrescriber()

  Dim res As Result

  If modBasic.$MedNarcoPrescriber = "User" Then
    res = modDatabase.$myConn.Exec("select fldusername,fldusercode from tbluser where flduserid=&1 and (fldopconsult=&2 or fldipconsult=&2) and fldstatus=&3 and fldusercode like &4", modBasic.$lbluser, True, "Active", "%")
    If res.Available Then
      $NarcoDoctor = res["fldusername"]
      $NarcoRegd = res["fldusercode"]
    Endif
  Endif

End

Private Sub ShowBasicParamStatus()

  Dim xmsg As String

  If $ShowReview = "None" Then
  Else

    xmsg = ""
    If Not $PatHeight Then
      $PatHeight = modSysCons.GetPatientEmptyHeight($PatAge, $PatSex)
      If $PatHeight Then
        xmsg = "Patient's height not set. Using " & $PatHeight & " cm for now" & gb.NewLine
      Endif
    Endif
    If Not $PatWeight Then
      If $PatHeight Then
        $PatWeight = modSysCons.GetPatientEmptyWeight($PatHeight, $PatSex)
        If $PatWeight Then
          xmsg = xmsg & "Patient's weight not set. Using " & $PatWeight & " Kg for now"
        Endif
      Endif
    Endif

    If xmsg Then
      Message.Warning(xmsg, ("OK"))
    Endif

  Endif

End

Public Sub btnshow_Click()

  LoadMedicineGrid()

End

Private Sub LoadMedicineGrid()

  Dim sFieldLst As String[]
  Dim sql As String

  sFieldLst = ["fldid", "fldroute", "flditem", "flddose", "fldfreq", "flddays", "fldcurval", "fldqtyorder", "fldid", "flduserid", "fldstarttime", "fldid", "flddirection", "fldadminsite", "fldmixing", "flduserid"]
  If cmbstatus.Text = "%" Then
    sql = "select " & sFieldLst.Join(",") & " from tblinpatdosing where fldencounterval=&1 ORDER BY fldstarttime DESC"
  Else
    sql = "select " & sFieldLst.Join(",") & " from tblinpatdosing where fldencounterval=&1 and fldcurval=&2 and fldsave=&3 ORDER BY fldstarttime DESC"
  Endif
  $rData = modDatabase.$myConn.Exec(sql, $encid, cmbstatus.Text, False)
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 75 * modBasic.$AppWidthRatio
    .Columns[2].Width = 300 * modBasic.$AppWidthRatio
    .Columns[3].Width = 75 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 100 * modBasic.$AppWidthRatio
    .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    .Columns[8].Width = 25 * modBasic.$AppWidthRatio
    .Columns[9].Width = 125 * modBasic.$AppWidthRatio
    .Columns[10].Width = 150 * modBasic.$AppWidthRatio
    .Columns[11].Width = 50 * modBasic.$AppWidthRatio
    .Columns[12].Width = 150 * modBasic.$AppWidthRatio
    .Columns[13].Width = 150 * modBasic.$AppWidthRatio
    .Columns[14].Width = 150 * modBasic.$AppWidthRatio
    .Columns[15].Width = 1

    .Columns[1].Text = "Route"
    .Columns[2].Text = "Medicine"
    .Columns[3].Text = "Dose"
    .Columns[4].Text = "Freq"
    .Columns[5].Text = "Days"
    .Columns[6].Text = "Status"
    .Columns[7].Text = "QTY"
    .Columns[9].Text = "Doctor"
    .Columns[10].Text = "Start"
    .Columns[11].Text = "N"
    .Columns[12].Text = "Direction"
    .Columns[13].Text = "Admin"
    .Columns[14].Text = "Dilution"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 8 Then
    GridView1.Data.Picture = Picture["icons/checked.png"]
    GridView1.Data.Text = ""
  Else If Column = 9 Then
    GridView1.Data.Text = modGeneral.GetUserFullName($rData[$aMyFields[Column]])
  Else If Column = 10 Then
    GridView1.Data.Text = modReportVar.GetDateTimeReport($rData[$aMyFields[Column]], gb.GeneralDate)
  Else If Column = 11 Then
    GridView1.Data.Text = ""
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif
  GridView1.Rows[Row].Height = Max(GridView1.Rows[Row].Height, GridView1.Data.Font.RichTextHeight(GridView1.Data.Text, GridView1.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (GridView1.Rows.Height - GridView1.Font.Height))
  GridView1.Data.WordWrap = True

End

Public Sub GridView1_Click()

  Dim xval As Float
  Dim yval As String
  Dim Column As Integer
  Dim res As Result

  If GridView1.Column = 8 Then
    modGridView.CheckUncheckGridNoDB(GridView1, 8)

  Else If GridView1.Column = 3 Then ''dose
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 15].Text) = True Then
      If GridView1[GridView1.Row, 3].Text Then
        xval = InputValue(GridView1[GridView1.Row, 2].Text, ("Alter Unit Dose"), GridView1[GridView1.Row, 3].Text)
      Else
        xval = InputValue(GridView1[GridView1.Row, 2].Text, ("Alter Unit Dose"), 0)
      Endif
      If xval Then
        res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
        res["flddose"] = xval
        res["xyz"] = False
        res.Update
        LoadMedicineGrid()
      Endif
    Endif

  Else If GridView1.Column = 4 Then ''Freq
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 15].Text) = True Then
      yval = InputCombo(GridView1[GridView1.Row, 2].Text, ("Alter Frequency"), modMedicine.FrequencyCombo(), GridView1[GridView1.Row, 4].Text, True)
      If yval Then
        res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
        res["fldfreq"] = yval
        res["xyz"] = False
        res.Update
        LoadMedicineGrid()
      Endif
    Endif

  Else If GridView1.Column = 5 Then ''Days
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 15].Text) = True Then
      xval = InputValue(GridView1[GridView1.Row, 2].Text, ("Alter Duration"), GridView1[GridView1.Row, 5].Text)
      If xval Then
        res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
        res["flddays"] = xval
        res["fldendtime"] = DateAdd(res["fldstarttime"], gb.Hour, CInt(xval * 24))
        res["xyz"] = False
        res.Update
        LoadMedicineGrid()
      Endif
    Endif

  Else If GridView1.Column = 6 Then ''Status
    yval = InputCombo(GridView1[GridView1.Row, 2].Text, ("Alter Status"), $StateList, GridView1[GridView1.Row, 6].Text, True)
    If yval Then
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
      res["fldcurval"] = yval
      res["xyz"] = False
      res.Update
      LoadMedicineGrid()
    Endif

  Else If GridView1.Column = 7 Then  ''QTY
    xval = InputValue(GridView1[GridView1.Row, 2].Text, ("Alter Quantity"), GridView1[GridView1.Row, 7].Text)
    If xval Then
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
      res["fldqtyorder"] = xval
      res["xyz"] = False
      res.Update
      LoadMedicineGrid()
    Endif

  Else If GridView1.Column = 12 Then ''Direction
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 15].Text) = True Then
      yval = GetTextArea(GridView1[GridView1.Row, 2].Text, GridView1[GridView1.Row, 12].Text)
      If yval Then
        res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
        res["flddirection"] = Trim(yval)
        res["xyz"] = False
        res.Update
        LoadMedicineGrid()
      Endif
    Endif

  Else If GridView1.Column = 13 Then ''Admin
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 15].Text) = True Then
      yval = InputBox(GridView1[GridView1.Row, 2].Text, "Site of Administration", GridView1[GridView1.Row, 13].Text)
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
      res["fldadminsite"] = Trim(yval)
      res["xyz"] = False
      res.Update
      LoadMedicineGrid()
    Endif

  Else If GridView1.Column = 14 Then ''Dilution
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 15].Text) = True Then
      yval = InputBox(GridView1[GridView1.Row, 2].Text, "Dilution Fluid", GridView1[GridView1.Row, 14].Text)
      res = modDatabase.$myConn.Edit("tblinpatdosing", "fldid=&1 and fldencounterval=&2", GridView1[GridView1.Row, 0].Text, $encid)
      res["fldmixing"] = Trim(yval)
      res["xyz"] = False
      res.Update
      LoadMedicineGrid()
    Endif
  Endif

End

