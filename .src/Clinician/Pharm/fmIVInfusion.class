' Gambas class file

Private $encid As String
Private $useCardex As Boolean

Private $rFludRes As Result
Private $aFludFields As String[]
Private $rRateRes As Result
Private $aRateFields As String[]

Public Sub _new(encid As String, useCardex As Boolean)

  $encid = encid
  $useCardex = useCardex

End

Public Sub Form_Open()

  Dim xstatus As String

  modGeneralMain.ArrangeFormCentre(Me, "False")
  txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
  txtgender.Text = modDate.GetAgeString(modPatient.GetPatientBirthDay($encid), Now()) & "/" & modPatient.GetPatientSex($encid)

  xstatus = modPatient.CurrentAdmissionStatus($encid)
  txtlocation.Text = modPatient.GetLocationSetting($encid, xstatus)
  If $useCardex = True Then
    chkalldate.Visible = False
  Else
    chkalldate.Visible = True
  Endif
  ShowMedFluids()

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Endif

End

Public Sub chkalldate_Click()

  ShowMedFluids()

End

Private Sub ShowMedFluids()

  Dim sql As String
  Dim sql1 As String
  Dim sql2 As String
  Dim xrouLst As String[] = ["fluid", "CIV", "CIn(Epid)", "CIn(Block)"]
  Dim j As Integer

  For j = 0 To xrouLst.Count - 1
    xrouLst[j] = "'" & xrouLst[j] & "'"
  Next

  If $useCardex = True Then
    sql1 = "select fldid,fldid,CONCAT(flditem, '|', COALESCE(fldmixing, '')),flddose,fldfreq,flddays,fldstarttime,fldcurval,fldstarttime,fldcurval,fldendtime,flddirection,fldadminsite,fldmixing,fldroute,flditem,fldmixvolume,fldmixrate from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&2 and flddose>&3 and flddays>&3 and fldstarttime<=&4 and fldendtime>=&5"
    sql2 = "select fldid,fldid,CONCAT(flditem, '|', COALESCE(fldmixing, '')),flddose,fldfreq,flddays,fldstarttime,fldcurval,fldstarttime,fldcurval,fldendtime,flddirection,fldadminsite,fldmixing,fldroute,flditem,fldmixvolume,fldmixrate from tblinpatdosing where fldencounterval=&1 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&3 and flddays=&3"
    $rFludRes = modDatabase.$myConn.Exec(sql1 & " UNION " & sql2, $encid, "Continue", 0, Now(), DateAdd(Now(), gb.Hour, -3))
  Else
    If chkalldate.Value = True Then
      sql = "select fldid,fldid,CONCAT(flditem, '|', COALESCE(fldmixing, '')),flddose,fldfreq,flddays,fldstarttime,fldcurval,fldstarttime,fldstatus,fldendtime,flddirection,fldadminsite,fldmixing,fldroute,flditem,fldmixvolume,fldmixrate from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&4 ORDER BY fldstarttime DESC"
      $rFludRes = modDatabase.$myConn.Exec(sql, $encid, True, "Continue", 0)
    Else
      sql = "select fldid,fldid,CONCAT(flditem, '|', COALESCE(fldmixing, '')),flddose,fldfreq,flddays,fldstarttime,fldcurval,fldstarttime,fldstatus,fldendtime,flddirection,fldadminsite,fldmixing,fldroute,flditem,fldmixvolume,fldmixrate from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldroute IN(" & xrouLst.Join(",") & ") and fldcurval=&3 and flddose>&4 and fldstarttime<=&5 and fldendtime>=&6 ORDER BY fldstarttime DESC"
      $rFludRes = modDatabase.$myConn.Exec(sql, $encid, True, "Continue", 0, modDate.EndSqlDate(Now()), modDate.StartSqlDate(Now()))
    Endif
  Endif
  $aFludFields = New String[]
  modGridView.ReadSmallData(grdfluid, $rFludRes, $aFludFields)

  With grdfluid
    .Columns[0].Width = 1
    .Columns[1].Width = 40 * modBasic.$AppWidthRatio
    .Columns[2].Width = 400 * modBasic.$AppWidthRatio
    .Columns[3].Width = 75 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 1
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 100 * modBasic.$AppWidthRatio
    .Columns[8].Width = 1 ''start time
    .Columns[9].Width = 1
    .Columns[10].Width = 1 ''end time
    .Columns[11].Width = 1 ''direction
    .Columns[12].Width = 1 ''admin site
    .Columns[13].Width = 1 ''dilution
    .Columns[14].Width = 1  ''route
    .Columns[15].Width = 1 ''Item name
    .Columns[16].Width = 1 ''Mix Volume
    .Columns[17].Width = 75 * modBasic.$AppWidthRatio

    .Columns[2].Text = "Medicine"
    .Columns[3].Text = "Dose"
    .Columns[4].Text = "Freq"
    .Columns[6].Text = "Date"
    .Columns[7].Text = "Status"
    .Columns[17].Text = "mL/Hour"
  End With

End

Public Sub grdfluid_Data(Row As Integer, Column As Integer)

  $rFludRes.MoveTo(Row)
  modGeneralMain.GridViewDecoration(grdfluid, Row)
  If Column = 1 Then
    grdfluid.Data.Picture = Picture[GetFluidAdminStatusCode($rFludRes[$aFludFields[Column]])]
    grdfluid.Data.Text = ""
  Else If Column = 2 Then
    grdfluid.Data.RichText = GetInjectionName($rFludRes[$aFludFields[Column]])
  Else If Column = 6 Then
    grdfluid.Data.Text = modReportVar.GetDateTimeReport($rFludRes[$aFludFields[Column]], gb.GeneralDate)
  Else
    grdfluid.Data.Text = $rFludRes[$aFludFields[Column]]
  Endif
  grdfluid.Rows[Row].Height = Max(grdfluid.Rows[Row].Height, grdfluid.Data.Font.RichTextHeight(grdfluid.Data.RichText, grdfluid.Columns[Column].Width - 5 * modBasic.$AppWidthRatio) + (grdfluid.Rows.Height - grdfluid.Font.Height))
  grdfluid.Data.WordWrap = True

End

Private Function GetInjectionName(sItem As String) As String

  Dim asx As String[]
  Dim xx As String

  asx = Split(sItem, "|")
  If asx.Count = 2 Then
    If Trim(asx[1]) Then
      xx = asx[0] & " <small>[" & asx[1] & "]</small>"
    Else
      xx = asx[0]
    Endif
  Else
    xx = asx[0]
  Endif

  Return xx

End

Public Sub btndirection_Click()

  If grdfluid.Rows.Selection.Count Then
    lblduration.Text = grdfluid[grdfluid.Row, 11].Text
  Endif

End

Public Sub btnfluid_Click()

  If grdfluid.Rows.Selection.Count Then
    lblduration.Text = grdfluid[grdfluid.Row, 13].Text & "  Volume: " & grdfluid[grdfluid.Row, 16].Text & " mL"
  Endif

End

Public Sub btnprotocol_Click()

  Dim res As Result
  Dim hForm As FmInjection

  If grdfluid.Rows.Selection.Count Then
    res = modDatabase.$medConn.Exec("select fldlabel from tbllabel where flddrug=&1 and fldsubroute=&2", modMedConstant.GetDrugFromStockID(grdfluid[grdfluid.Row, 15].Text), grdfluid[grdfluid.Row, 14].Text)
    If res.Available Then
      res.MoveFirst
      hForm = New FmInjection(grdfluid[grdfluid.Row, 14].Text, res["fldlabel"])
      hForm.ShowModal
    Endif
  Endif

End

Private Function GetDateTimeLabel(dt1 As Date, dt2 As Date) As String

  Dim xx As String

  If dt2 Then
    If modDate.StartSqlDate(dt1) = modDate.StartSqlDate(dt2) Then
      xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate) & " TO " & modReportVar.GetDateTimeReport(dt2, gb.MediumTime)
    Else
      xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate) & " TO " & modReportVar.GetDateTimeReport(dt2, gb.GeneralDate)
    Endif
  Else
    xx = modReportVar.GetDateTimeReport(dt1, gb.GeneralDate)
  Endif
  Return xx

End

Public Sub btntime_Click()

  If grdfluid.Rows.Selection.Count Then
    lblduration.Text = GetDateTimeLabel(grdfluid[grdfluid.Row, 8].Text, grdfluid[grdfluid.Row, 10].Text)
  Endif

End

Public Sub grdfluid_Click()

  Dim xx As String[] = ["Continue", "Discontinue", "On Hold", "Cancelled"]
  Dim res As Result
  Dim xval As String
  Dim yval As Integer
  Dim Row As Integer

  Row = grdfluid.Row
  txtfluidname.Text = grdfluid[grdfluid.Row, 15].Text
  FillFluidGridView(grdfluid[grdfluid.Row, 0].Text)
  lblduration.Text = grdfluid[grdfluid.Row, 11].Text
  If grdfluid.Column = 7 Then
    If $useCardex = False Then
      xval = InputCombo(grdfluid[grdfluid.Row, 15].Text, ("Select Current Status"), xx, grdfluid[grdfluid.Row, 7].Text, True)
      If xval Then
        res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1", grdfluid[grdfluid.Row, 0].Text)
        res["fldcurval"] = xval
        res["xyz"] = False
        res.Update()
        ShowMedFluids()
      Endif
    Endif

  Else If grdfluid.Column = 1 Then
    If grdfluid[grdfluid.Row, 7].Text = "Continue" Then
      If grdfluid[grdfluid.Row, 1].Picture = Picture["icon:/tiny/next"] Then
        yval = InputValue(("Enter Rate of Administration in ") & "<b>mL/Hour</b> FOR <b>" & grdfluid[grdfluid.Row, 15].Text & "</b>", "Administration Rate", 0)
        If yval Then
          If $useCardex = True Then
            modPharmSub.InsertNurDosingIndoor($encid, 0, grdfluid[grdfluid.Row, 0].Text, yval, "mL/Hour", grdfluid[grdfluid.Row, 15].Text, grdfluid[grdfluid.Row, 3].Text, grdfluid[grdfluid.Row, 4].Text, Now())
          Else
            modPharmSub.InsertNurDosingIndoor($encid, grdfluid[grdfluid.Row, 0].Text, 0, yval, "mL/Hour", grdfluid[grdfluid.Row, 15].Text, grdfluid[grdfluid.Row, 3].Text, grdfluid[grdfluid.Row, 4].Text, Now())
          Endif
          FillFluidGridView(grdfluid[grdfluid.Row, 0].Text)
          ShowMedFluids()
        Endif
      Endif
    Endif

  Else If grdfluid.Column = 17 Then
    If $useCardex = False Then
      yval = InputValue(("Enter New Rate of Administration in ") & "<b>mL/Hour</b> FOR <b>" & grdfluid[grdfluid.Row, 15].Text & "</b>", "Administration Rate", grdfluid[grdfluid.Row, 17].Text)
      If yval Then
        res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1", grdfluid[grdfluid.Row, 0].Text)
        res["fldmixrate"] = yval
        res["xyz"] = False
        res.Update()
        ShowMedFluids()
      Endif
    Endif

  Endif
  grdfluid.Row = Row

End

Private Sub FillFluidGridView(dosno As Long)

  If $useCardex = True Then
    $rRateRes = modDatabase.$syConn.Exec("select fldid,fldid,fldvalue,fldunit,fldid,fldfromtime,fldtotime,fldcardex from tblnurdosing where fldencounterval=&1 and fldcardex=&2 and fldfromtime IS NOT NULL ORDER BY fldid DESC", $encid, dosno)
  Else
    $rRateRes = modDatabase.$syConn.Exec("select fldid,fldid,fldvalue,fldunit,fldid,fldfromtime,fldtotime,flddoseno from tblnurdosing where fldencounterval=&1 and flddoseno=&2 and fldfromtime IS NOT NULL ORDER BY fldid DESC", $encid, dosno)
  Endif
  $aRateFields = New String[]
  modGridView.ReadSmallData(grdfluiddata, $rRateRes, $aRateFields)

  With grdfluiddata
    .Columns[0].Width = 1
    .Columns[1].Width = 400 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 40 * modBasic.$AppWidthRatio
    .Columns[5].Width = 150 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 1

    .Columns[1].Text = "Particulars"
    .Columns[2].Text = "Rate"
    .Columns[3].Text = "Unit"
    .Columns[5].Text = "Start"
    .Columns[6].Text = "Close"
  End With

End

Public Sub grdfluiddata_Data(Row As Integer, Column As Integer)

  $rRateRes.MoveTo(Row)
  modGeneralMain.GridViewDecoration(grdfluiddata, Row)
  If Column = 1 Then
    grdfluiddata.Data.Text = txtfluidname.Text
  Else If Column = 2 Then
    grdfluiddata.Data.Text = $rRateRes[$aRateFields[Column]]
    grdfluiddata.Data.Alignment = Align.Right
  Else If Column = 4 Then
    grdfluiddata.Data.Picture = Picture[GetPictureDosing($rRateRes[$aRateFields[Column]])]
  Else If Column = 5 Then
    grdfluiddata.Data.Text = modReportVar.GetDateTimeReport($rRateRes[$aRateFields[Column]], gb.GeneralDate)
  Else If Column = 6 Then
    grdfluiddata.Data.Text = modReportVar.GetDateTimeReport($rRateRes[$aRateFields[Column]], gb.GeneralDate)
  Else
    grdfluiddata.Data.Text = $rRateRes[$aRateFields[Column]]
  Endif

End

Public Sub grdfluiddata_Click()

  Dim res As Result
  Dim Row As Integer

  If grdfluiddata.Column = 4 Then
    If grdfluiddata[grdfluiddata.Row, 4].Picture = Picture["icon:/tiny/stop"] Then
      Row = grdfluid.Row
      res = modDatabase.$myConn.Edit("tblnurdosing", "fldid=&1", grdfluiddata[grdfluiddata.Row, 0].Text)
      res["fldtotime"] = Now()
      res["xyz"] = False
      res.Update
      FillFluidGridView(grdfluiddata[grdfluiddata.Row, 7].Text)
      ShowMedFluids()
      grdfluid.Row = Row
    Endif
  Endif

End

Private Function GetPictureDosing(dosid As Long) As String

  Dim res As Result
  Dim xx As String

  res = modDatabase.$myConn.Exec("select flddoseno,fldfromtime,fldtotime from tblnurdosing where fldid=&1", dosid)
  If res.Available Then
    If res["fldfromtime"] And If Not res["fldtotime"] Then
      xx = "icon:/tiny/stop"
    Else If res["fldfromtime"] And If res["fldtotime"] Then
      xx = "icon:/tiny/lock"
    Endif
  Endif
  Return xx

End

Private Function GetFluidAdminStatusCode(dosno As Long) As String

  Dim res As Result
  Dim xx As String

  If $useCardex = True Then
    res = modDatabase.$syConn.Exec("select fldid,fldfromtime,fldtotime from tblnurdosing where fldencounterval=&1 and fldcardex=&2 ORDER BY fldid DESC", $encid, dosno)
  Else
    res = modDatabase.$syConn.Exec("select fldid,fldfromtime,fldtotime from tblnurdosing where fldencounterval=&1 and flddoseno=&2 ORDER BY fldid DESC", $encid, dosno)
  Endif
  If res.Available Then
    If res["fldfromtime"] And If Not res["fldtotime"] Then
      xx = "icon:/tiny/stop"
    Else
      xx = "icon:/tiny/next"
    Endif
  Else
    xx = "icon:/tiny/next"
  Endif
  Return xx

End
