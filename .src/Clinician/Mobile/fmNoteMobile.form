# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,91,55)
  Text = ("Patient Notes")
  Arrangement = Arrange.Vertical
  Margin = True
  { Panel1 Panel
    MoveScaled(0,0,88,4)
    { txtname TextBox
      MoveScaled(9,0.5,37.5,3)
      Font = Font["Bold"]
      ReadOnly = True
    }
    { Label2 Label
      MoveScaled(1,0.5,7,3)
      Border = Border.Plain
      Text = ("Name")
    }
  }
  { TabPanel1 TabPanel
    MoveScaled(0,4,89,49)
    Expand = True
    Arrangement = Arrange.Vertical
    Count = 2
    Index = 0
    Text = ("History")
    { Panel2 Panel
      MoveScaled(0,0,87.875,4.25)
      { btnshownote Button
        MoveScaled(73,0.5,14,3)
        Text = ("Refresh")
        Picture = Picture["icon:/small/refresh"]
      }
      { Panel4 Panel
        MoveScaled(1,0.5,66,3)
        { rbprogress RadioButton
          MoveScaled(0,0,12,3)
          Text = ("Progress")
          Value = True
        }
        { rbclinician RadioButton
          MoveScaled(13,0,12,3)
          Text = ("Clinicians")
        }
        { rbnurses RadioButton
          MoveScaled(26,0,12,3)
          Text = ("Nurses")
        }
        { rbtransfer RadioButton
          MoveScaled(39,0,12,3)
          Text = ("Transfer")
        }
        { rbdoctor RadioButton
          MoveScaled(52,0,12,3)
          Text = ("Dr Order")
        }
      }
    }
    { GridView1 GridView
      MoveScaled(5,8,66,28)
      Expand = True
      Mode = Select.Single
      Header = GridView.Both
      AutoResize = False
    }
    Index = 1
    Text = ("New Note")
    { Panel3 Panel
      MoveScaled(0,0,87,4)
      { cmbnote ComboBox
        MoveScaled(12,0.5,28,3)
      }
      { btnsaveall Button
        MoveScaled(53,0.5,15,3)
        Text = ("Save")
        Picture = Picture["icon:/small/apply"]
      }
      { btnclose Button
        MoveScaled(69,0.5,11,3)
        Text = ("Close")
        Cancel = True
      }
      { Label1 Label
        MoveScaled(0.5,0.5,11,3)
        Border = Border.Plain
        Text = ("Category")
      }
    }
    { txtnote TextHTML
      MoveScaled(3,10,66,17)
      Expand = True
    }
    { Panel5 Panel
      MoveScaled(0,38,87,4)
      { txtimpression ComboBox
        MoveScaled(12,0.5,66,3)
      }
      { btnhelpplanfinal ToolButton
        MoveScaled(79,0.5,3,3)
        Picture = Picture["icon:/small/exec"]
      }
      { btntemplpplanfinal ToolButton
        MoveScaled(83,0.5,3,3)
        Picture = Picture["icon:/small/attach"]
      }
      { Label3 Label
        MoveScaled(0.5,0.5,11,3)
        Border = Border.Plain
        Text = ("Impression")
      }
    }
    Index = 0
  }
}
