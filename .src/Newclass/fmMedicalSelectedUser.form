# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,37,65)
  Resizable = False
  Arrangement = Arrange.Vertical
  Margin = True
  { Panel2 Panel
    MoveScaled(0,0,36,3.5)
    Border = Border.Plain
    { rbuser RadioButton
      MoveScaled(1,0.25,14,3)
      Text = ("User ID")
      Value = True
    }
    { rbname RadioButton
      MoveScaled(17,0.25,14,3)
      Text = ("User Name")
    }
  }
  { Panel1 Panel
    MoveScaled(0,4,35.875,3.5)
    { btnsel Button
      MoveScaled(32,0,3,3)
      Picture = Picture["icon:/small/apply"]
    }
    { txtsearch TextBox
      MoveScaled(0,0,31,3)
    }
  }
  { ListView1 ListView
    MoveScaled(1,8,35,33)
    Expand = True
  }
}
