# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,39,61)
  Resizable = False
  Arrangement = Arrange.Vertical
  Margin = True
  { Panel2 Panel
    MoveScaled(0,0,39,3.5)
    Border = Border.Plain
    { rbuser RadioButton
      MoveScaled(1,0.25,14,3)
      Text = ("User ID")
      Value = True
    }
    { rbname RadioButton
      MoveScaled(19,0.25,14,3)
      Text = ("User Name")
    }
  }
  { Panel1 Panel
    MoveScaled(0,4,39,3.5)
    { txtsearch TextBox
      MoveScaled(5,0,21,3)
    }
    { btnsel Button
      MoveScaled(27,0,10,3)
      Text = ("Save")
      Picture = Picture["icon:/small/apply"]
    }
    { btncuruser ToolButton
      MoveScaled(0,0,3,3)
      Picture = Picture["icon:/small/user"]
    }
  }
  { ListView1 ListView
    MoveScaled(1,11,35,28)
    Expand = True
  }
}
