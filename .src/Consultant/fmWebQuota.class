' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbcategory.List = ["General OPD"]
  dtquota.Value = Now()
  cmbdisctype.List = modControlSub.GetDirectFillresult(modDatabase.$myConn.Exec("select fldtype from tbldiscount where fldonline=&1", "Enable"))
  cmbdisctype.Add("%")
  cmbdepart.List = modGeneral.RegistrationDeptList()

End

Public Sub dtnepquota_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtquota.Value))
  If xx Then
    dtquota.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub btnconsult_Click()

  Dim xMedUser As String[]

  xMedUser = MedicalSelectedValue(("Select Consultant"), modBasic.$OPConsulUserList)
  If xMedUser And If xMedUser.Count Then
    btnconsult.Tag = xMedUser[0]
    btnconsult.Text = xMedUser[1]
  Else
    btnconsult.Tag = ""
    btnconsult.Text = ""
  Endif

End

Public Sub btnconsult_Change()

  If btnconsult.Text = "" Then
    btnconsult.Tag = ""
  Endif

End

Public Sub cmbdisctype_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbdisctype)
  modFillContainer.RestrictComboToContent(cmbdisctype)

End

Public Sub cmbdisctype_LostFocus()

  If cmbdisctype.Text Then
    txtbillmode.Text = modNonMedical.GetDiscBindBillMode(cmbdisctype.Text)
  Endif

End

Public Sub cmbdepart_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbdepart)
  modFillContainer.RestrictComboToContent(cmbdepart)

End

Public Sub cmbpayment_GotFocus()

  Dim xLst As String[]

  If cmbdisctype.Text And If txtbillmode.Text Then
    If Not cmbpayment.Text Then
      xLst = modNonMedical.NonStockBillActiveItemArray(modNonMedical.GetBillItemCategoryFromCombo("Service"), txtbillmode.Text)
      If xLst.Count Then
        cmbpayment.Text = GridViewNew("Select Particulars", xLst, False, cmbpayment, GridView1.Height)
        If cmbpayment.Text Then
          txtpaycost.Value = modNonMedical.GetCashBillItemCost(cmbpayment.Text, "General Services")
        Endif
      Endif
    Endif
  Endif

End

Private Sub CLearComntrols()

  cmbdisctype.Text = ""
  cmbdepart.Text = ""
  btnconsult.Tag = ""
  btnconsult.Text = ""
  cmbpayment.Text = ""
  txtpaycost.Value = 0
  txtquota.Value = 0

End

Public Sub btnadd_Click()

  Dim res As Result

  If cmbdisctype.Text And If cmbdepart.Text And If cmbpayment.Text Then
    res = modDatabase.$myConn.Create("tblquota")
    res["fldgroup"] = cmbcategory.Text
    res["fldscheme"] = cmbdisctype.Text
    res["fldconsultdate"] = dtquota.Value
    res["flddepartment"] = cmbdepart.Text
    res["fldconsultant"] = btnconsult.Text & ":" & btnconsult.Tag
    res["flditemname"] = cmbpayment.Text
    res["flditemcost"] = txtpaycost.Value
    res["fldwebquota"] = txtquota.Value

    res["flduserid"] = modBasic.$lbluser
    res["fldtime"] = Now()
    res["fldcomp"] = modBasic.$compID
    res["fldsave"] = True
    res["flduptime"] = ""
    res.Update
    ShowGridView()
    CLearComntrols()
  Endif

End

Public Sub Button1_Click()

  If dtquota.Value Then
    ShowGridView()
  Endif

End

Private Sub ShowGridView()

  $rData = modDatabase.$myConn.Exec("select fldid,fldconsultdate,flddepartment,fldscheme,fldconsultant,fldwebquota,flditemname,flditemcost from tblquota where fldgroup=&1 and fldconsultdate>=&2 and fldconsultdate<=&3", cmbcategory.Text, modDate.StartSqlDate(dtquota.Value), modDate.EndSqlDate(dtquota.Value))                                  ''
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 1
    .Columns[2].Width = 150 * modBasic.$AppWidthRatio
    .Columns[3].Width = 125 * modBasic.$AppWidthRatio
    .Columns[4].Width = 150 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 200 * modBasic.$AppWidthRatio
    .Columns[7].Width = 75 * modBasic.$AppWidthRatio

    .Columns[2].Text = "Department"
    .Columns[3].Text = "Package"
    .Columns[4].Text = "Consultant"
    .Columns[5].Text = "Quota"
    .Columns[6].Text = "Payment"
    .Columns[7].Text = "Rate"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  GridView1.Data.Text = $rData[$aMyFields[Column]]

End

Public Sub btndelete_Click()

  If GridView1.Rows.Selection.Count Then
    modDatabase.$myConn.Delete("tblquota", "fldid=&1", GridView1[GridView1.Row, 0].Text)
    ShowGridView()
    CLearComntrols()
  Endif

End

Public Sub btnexport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "WEB QUOTA ALLOCATION", modReportVar.GetDateTimeReport(dtquota.Value, gb.MediumDate))

End

Public Sub GridView1_Click()

  Dim res As Result
  Dim xstr As String
  Dim xval As Float
  Dim xLst As String[]

  If GridView1.Column = 3 Then
    xstr = InputCombo("Select Package Name", "Update", cmbdisctype.List, GridView1[GridView1.Row, 3].Text, True)
    If xstr Then
      res = modDatabase.$myConn.Edit("tblquota", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      res["fldscheme"] = xstr
      res.Update
      ShowGridView()
    Endif

  Else If GridView1.Column = 5 Then
    xval = InputValue("Update Quota Count", "Update", GridView1[GridView1.Row, 5].Text)
    If xval Then
      res = modDatabase.$myConn.Edit("tblquota", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      res["fldwebquota"] = xval
      res.Update
      ShowGridView()
    Endif

  Else If GridView1.Column = 6 Then
    xLst = modNonMedical.NonStockBillActiveItemArray(modNonMedical.GetBillItemCategoryFromCombo("Service"), modNonMedical.GetDiscBindBillMode(GridView1[GridView1.Row, 3].Text))
    If xLst.Count Then
      xstr = GridViewNew("Select Particulars", xLst, False, GridView1, GridView1.Height)
      If xstr Then
        res = modDatabase.$myConn.Edit("tblquota", "fldid=&1", GridView1[GridView1.Row, 0].Text)
        res["flditemname"] = xstr
        res["flditemcost"] = modNonMedical.GetCashBillItemCost(xstr, "General Services")
        res.Update
        ShowGridView()
      Endif
    Endif

  Endif

End

Public Sub btncopy_Click()

  Dim xdate As Date
  Dim res As Result
  Dim res1 As Result

  If GridView1.Rows.Count Then
    xdate = GetDateValue("Select Date For Consultation", "Copy Booking Quota", Now())
    If xdate Then
      res1 = modDatabase.$myConn.Exec("select fldgroup,fldscheme,flddepartment,fldconsultant,flditemname,flditemcost,fldwebquota from tblquota where fldid=&1", GridView1[GridView1.Row, 0].Text)
      cmbcategory.Text = res1["fldgroup"]
      dtquota.Value = xdate

      res = modDatabase.$myConn.Create("tblquota")
      res["fldgroup"] = res1["fldgroup"]
      res["fldscheme"] = res1["fldscheme"]
      res["fldconsultdate"] = xdate
      res["flddepartment"] = res1["flddepartment"]
      res["fldconsultant"] = res1["fldconsultant"]
      res["flditemname"] = res1["flditemname"]
      res["flditemcost"] = res1["flditemcost"]
      res["fldwebquota"] = res1["fldwebquota"]

      res["flduserid"] = modBasic.$lbluser
      res["fldtime"] = Now()
      res["fldcomp"] = modBasic.$compID
      res["fldsave"] = True
      res["flduptime"] = ""
      res.Update

      ShowGridView()
    Endif
  Endif

End
